---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';

const adres = 'Yıldız Teknik Üniversitesi Davutpaşa Kampüsü Teknopark, B1 Blok, No: 309, Esenler / İstanbul';
const eposta = 'info@focusclub360.com';
const haritaUrl = 'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent('Yıldız Teknik Üniversitesi Davutpaşa Teknopark B1 Blok Esenler İstanbul');
---

<Layout
  title="Bize Ulaşın | FocusClub 360"
  description="FocusClub 360 ile iletişime geçin. Adres ve e-posta bilgilerimiz."
>
  <div class="theme-v13 bg-[#131629] md:bg-[#131629] md:p-4">
    <div class="mx-auto max-w-[1400px] bg-white md:rounded-[8px] md:shadow-[0_30px_80px_rgba(110,124,255,.18)]">

      <!-- Sticky header -->
      <header class="sticky top-0 z-50 flex items-center justify-between gap-4 border-b border-[#2A2F52] px-6 py-4 backdrop-blur-sm md:px-10" style="background-color: rgba(27,33,64,0.97);">
        <a href="/" class="flex items-center gap-2" aria-label="FocusClub 360">
          <span class="grid h-9 w-9 place-items-center rounded-kart bg-gradient-to-br from-[#6E7CFF] to-[#2D3AAE] text-beyaz">
            <Icon name="sparkles" size={20} />
          </span>
          <span class="font-baslik text-xl font-extrabold tracking-tight text-[#FFFFFF]">FocusClub
            <span class="text-[#6E7CFF]">360</span>
          </span>
        </a>
        <a href="/" class="inline-flex items-center gap-1.5 text-sm font-medium text-[#8B96CC] transition hover:text-[#FFFFFF]">
          <span class="rotate-90 inline-block"><Icon name="chevron" size={15} /></span>
          Anasayfa
        </a>
      </header>

      <!-- İçerik -->
      <section class="bg-white px-6 py-14 md:px-10 md:py-20">
        <div class="mx-auto max-w-[900px]">

          <div class="reveal max-w-xl">
            <span class="inline-flex items-center rounded-md bg-gradient-to-r from-[#7c5cfc]/20 to-[#3b6ef0]/20 px-3 py-1 text-xs font-semibold text-[#8B9BFF]">
              İLETİŞİM
            </span>
            <h1 class="mt-4 font-baslik text-3xl font-extrabold leading-tight tracking-tight text-[#FFFFFF] md:text-4xl">
              Bize Ulaşın
            </h1>
            <p class="mt-4 text-base leading-relaxed text-[#8B96CC]">
              Sorularınız, üyelik ve destek talepleriniz için bize aşağıdaki kanallardan ulaşabilirsiniz. En kısa sürede size dönüş yapıyoruz.
            </p>
          </div>

          <div class="reveal mt-10 grid gap-5 sm:grid-cols-2">

            <!-- Adres -->
            <div class="rounded-[8px] border border-[#2A2F52] bg-[#1A1E3A] p-6">
              <span class="grid h-12 w-12 place-items-center rounded-[8px] bg-mor text-white">
                <Icon name="pin" size={22} />
              </span>
              <h2 class="mt-4 font-baslik text-base font-bold text-[#FFFFFF]">Adres</h2>
              <p class="mt-2 text-sm leading-relaxed text-[#8B96CC]">{adres}</p>
              <a href={haritaUrl} target="_blank" rel="noopener" class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[#8B9BFF] transition hover:text-[#FFFFFF]">
                Haritada Aç
                <Icon name="arrow" size={14} />
              </a>
            </div>

            <!-- E-posta -->
            <div class="rounded-[8px] border border-[#2A2F52] bg-[#1A1E3A] p-6">
              <span class="grid h-12 w-12 place-items-center rounded-[8px] bg-mavi text-white">
                <Icon name="mail" size={22} />
              </span>
              <h2 class="mt-4 font-baslik text-base font-bold text-[#FFFFFF]">E-posta</h2>
              <p class="mt-2 text-sm leading-relaxed text-[#8B96CC]">Her türlü soru ve talebiniz için yazabilirsiniz.</p>
              <a href={`mailto:${eposta}`} class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[#8B9BFF] transition hover:text-[#FFFFFF]">
                {eposta}
                <Icon name="arrow" size={14} />
              </a>
            </div>

          </div>

        </div>
      </section>

      <Footer />
    </div>
  </div>
</Layout>

<style is:global>
  .theme-v13 .bg-white { background-color: #1B2140; }
</style>
