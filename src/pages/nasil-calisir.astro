---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { Image } from 'astro:assets';
import heroGorsel from '../assets/nasil-calisir-hero.jpg';
import { UYELIK_URL, KAYIT_URL, SATIN_AL_URL, ROUTES } from '../config';

const menu = [
  { ad: 'Kulüpte Neler Var', href: ROUTES.kulupteNelerVar },
  { ad: 'Nasıl Çalışır',     href: ROUTES.nasilCalisir    },
  { ad: 'Velilere',          href: ROUTES.velilere         },
  { ad: 'Nasıl Üye Olunur',  href: ROUTES.nasilUyeOlunur  },
  { ad: 'Rehber',            href: ROUTES.rehber           },
];

const adimlar = [
  { no: '01', baslik: 'Üye Ol',                                             renk: 'bg-turkuaz' },
  { no: '02', baslik: 'Programa Katıl',                                     renk: 'bg-amber'   },
  { no: '03', baslik: 'Akıllı Öğretim Ekosistemine Erişim Kazan',           renk: 'bg-mor'     },
  { no: '04', baslik: 'Canlı Etüt Ve Soru-Cevap Derslerini Başlat',        renk: 'bg-mavi'    },
  { no: '05', baslik: 'Eğitim Koçunla Tanış Ve Destek Almaya Başla',       renk: 'bg-mercan'  },
  { no: '06', baslik: 'Gelişimini Anlık Olarak İzle',                      renk: 'bg-turkuaz' },
  { no: '07', baslik: 'Konu Kazanımlarını Ve Program Başarını Takip Et',   renk: 'bg-amber'   },
  { no: '08', baslik: 'Kariyer ve Okul Tercihlerin İçin Danışmanlık Al',   renk: 'bg-mor'     },
];

const haftaAkisi = [
  { etiket: 'Etüt Akşamı 1',  aciklama: 'Branş dersi etüdü',                             ikon: 'users'  },
  { etiket: 'Etüt Akşamı 2',  aciklama: 'Branş dersi etüdü',                             ikon: 'users'  },
  { etiket: 'Etüt Akşamı 3',  aciklama: 'Branş dersi etüdü',                             ikon: 'users'  },
  { etiket: 'Etüt Akşamı 4',  aciklama: 'Test ya da deneme sınavı ve canlı çözüm',       ikon: 'list'   },
  { etiket: 'Koç Görüşmesi',  aciklama: 'Bireysel motivasyon ve hedef',                    ikon: 'target' },
  { etiket: 'Veli Raporu',    aciklama: 'Haftalık özet veliye iletilir',                  ikon: 'bell'   },
];

const veliKartlari = [
  {
    baslik: 'Haftalık Rapor',
    aciklama: "Çocuğunuzun o haftaki çalışması ve katılımı özetlenir.",
    ikon: 'bell',
    renk: 'bg-mor',
  },
  {
    baslik: 'Aylık Değerlendirme',
    aciklama: 'Gelişim, eksikler ve sıradaki hedefler bütüncül paylaşılır.',
    ikon: 'eye',
    renk: 'bg-mavi',
  },
  {
    baslik: 'Dönem Seminerleri ve Atölyeler',
    aciklama: 'Veliye yönelik bilgilendirme ve destek buluşmaları.',
    ikon: 'users',
    renk: 'bg-turkuaz',
  },
];
---

<Layout
  title="Nasıl Çalışır | FocusClub 360"
  description="Kayıttan LGS'ye kadar tek bir akıllı sistem. Gerçek öğretmenler, koçluk ve yapay zekâ takibiyle çocuğunuzun bir haftası nasıl geçer, adım adım görün."
>
  <div class="theme-v13 bg-[#131629] md:bg-[#131629] md:p-4">
    <div class="mx-auto max-w-[1400px] bg-white md:rounded-[8px] md:shadow-[0_30px_80px_rgba(110,124,255,.18)]">

      <!-- Sticky header -->
      <div class="sticky top-0 z-50">
        <div class="flex items-center justify-center gap-2 bg-gradient-to-r from-[#2D3AAE] to-[#5060E0] px-4 py-2 text-center text-sm font-medium text-beyaz md:rounded-t-[8px]">
          <Icon name="gift" size={16} />
          Ücretsiz İki Hafta Deneyim Fırsatı
        </div>

        <header class="flex items-center justify-between gap-4 px-6 py-3 backdrop-blur-sm md:py-4 md:px-10" style="background-color: rgba(27,33,64,0.97);">
          <a href="/" class="flex items-center" aria-label="FocusClub 360"><img src="/FocusClub360_logoF_navy.png" alt="FocusClub 360" class="h-[54px] w-auto md:h-[72px]" /></a>

          <nav class="hidden items-center gap-7 lg:flex">
            {menu.map((m) => (
              <a
                href={m.href}
                class={`text-sm transition ${m.href === ROUTES.nasilCalisir ? 'font-semibold text-[#FFFFFF]' : 'font-medium text-[#8B96CC] hover:text-[#FFFFFF]'}`}
              >
                {m.ad}
              </a>
            ))}
          </nav>

          <div class="flex items-center gap-2 sm:gap-3">
            <a href={KAYIT_URL} class="hidden text-sm font-semibold text-[#FFFFFF] hover:opacity-70 sm:block">Üye Olun</a>
            <a
              href={UYELIK_URL}
              class="hidden rounded-buton bg-gradient-to-r from-[#6E7CFF] to-[#2D3AAE] px-5 py-2.5 text-sm font-semibold text-beyaz shadow-[0_8px_20px_rgba(110,124,255,.40)] transition hover:brightness-110 sm:inline-block"
            >2 Hafta Ücretsiz</a>
            <a href={SATIN_AL_URL} class="hidden text-sm font-semibold text-turkuaz hover:opacity-70 sm:block">Satın Al</a>
            <button id="mob-tog" aria-label="Menüyü aç" class="grid h-9 w-9 shrink-0 place-items-center rounded-[8px] border border-kenar text-[#FFFFFF] transition hover:bg-bulut focus:outline-none active:bg-[#1E2848] lg:hidden" style="-webkit-tap-highlight-color: transparent; background-color: #1B2140; -webkit-appearance: none; appearance: none;">
              <Icon name="menu" size={20} />
            </button>
          </div>
        </header>

        <!-- Marka satırı — header ile sabit (mobil/tablet) -->
        <div class="border-b border-kenar px-6 py-2 md:px-10 lg:hidden" style="background-color: rgba(27,33,64,0.97);">
          <p class="text-[13px] font-semibold leading-tight text-[#6E7CFF]">
            TÜRKİYE'NİN İLK VE TEK<br />DİJİTAL AKADEMİK ETÜT KULÜBÜ
          </p>
        </div>

        <nav id="mob-nav" class="hidden border-b border-kenar px-6 pb-5 pt-2 lg:hidden" style="background-color: #1B2140;">
          <div class="flex flex-col">
            {menu.map((m) => (
              <a href={m.href} class="mob-link rounded-[8px] px-3 py-2.5 text-sm font-medium text-[#8B96CC] transition hover:bg-bulut hover:text-[#FFFFFF]">{m.ad}</a>
            ))}
            <a href={KAYIT_URL} class="mob-link rounded-[8px] px-3 py-2.5 text-sm font-medium text-[#8B96CC] transition hover:bg-bulut hover:text-[#FFFFFF]">Üye Olun</a>
            <a href={SATIN_AL_URL} class="mob-link rounded-[8px] px-3 py-2.5 text-sm font-medium text-turkuaz transition hover:bg-bulut">Satın Al</a>
          </div>
          <a
            href={UYELIK_URL}
            class="mt-3 flex items-center justify-center gap-2 rounded-[8px] bg-gradient-to-r from-[#6E7CFF] to-[#2D3AAE] py-3 text-sm font-semibold text-beyaz"
          >
            2 Hafta Ücretsiz Dene
            <Icon name="arrow" size={16} />
          </a>
        </nav>
      </div>

      <!-- ── 1. HERO (banner) ──────────────────────────────────────────────── -->
      <div class="flex min-h-[calc(100svh-8rem)] flex-col md:min-h-[calc(100vh-9rem)]">
        <div class="flex min-h-0 flex-1 flex-col px-6 pb-4 md:px-10 md:pb-6">

          <!-- Badge -->
          <div class="pb-2 pt-3 md:pb-3 md:pt-4">
            <span class="flex w-full items-center gap-1 rounded-md bg-[#ede8ff] px-2.5 py-1 text-[14px] font-semibold text-[#3b6ef0] md:inline-flex md:w-auto md:gap-1.5 md:bg-gradient-to-r md:from-[#7c5cfc]/12 md:to-[#3b6ef0]/12 md:px-3 md:py-1 md:text-[18px]">
              <Icon name="star" size={12} class="text-[#7c5cfc] md:size-[14px]" />
              Nasıl Çalışır?
            </span>
          </div>

          <!-- Banner -->
          <div class="relative min-h-0 flex-1 overflow-hidden rounded-[8px]">
            <Image
              src={heroGorsel}
              alt="FocusClub 360 nasıl çalışır"
              widths={[768, 1280, 1600]}
              sizes="100vw"
              class="absolute inset-0 h-full w-full object-cover object-center"
              loading="eager"
            />
            <div class="absolute inset-0 md:hidden" style="background-color: rgba(19,22,41,0.75);"></div>
            <div class="absolute inset-0 hidden md:block" style="background: linear-gradient(to right, rgba(19,22,41,0.83) 0%, rgba(19,22,41,0.38) 45%, rgba(19,22,41,0.09) 100%);"></div>

            <!-- İçerik -->
            <div class="absolute inset-0 z-10 flex flex-col justify-evenly px-5 py-4 md:px-10 md:py-10">

              <div class="max-w-[62%] md:max-w-lg">
                <h1 class="font-baslik text-2xl font-extrabold tracking-tight text-white md:text-4xl lg:text-[2.8rem]" style="line-height: 1.2;">
                  5. Sınıftan LGS'ye Kadar Tek Bir Akıllı Sistem
                </h1>
                <p class="mt-2 text-sm text-white/80 md:mt-4 md:text-base">
                  Çocuğunuz üye olduğu andan sınava kadar; gerçek öğretmenler ve koçlarla çalışır, her adımı yapay zekâ takip eder. Süreç baştan sona planlıdır, siz de her aşamada bilgilendirilirsiniz.
                </p>
              </div>

              <div>
                <div class="flex flex-wrap gap-2 md:gap-3">
                  <a
                    href={UYELIK_URL}
                    class="inline-flex items-center gap-2 rounded-buton bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] py-1.5 pl-4 pr-1.5 text-sm font-semibold text-beyaz shadow-[0_12px_30px_rgba(40,40,120,.35)] transition hover:brightness-105 md:gap-3 md:py-2.5 md:pl-6 md:pr-2.5 md:text-base"
                  >
                    2 Hafta Ücretsiz Dene
                    <span class="grid h-7 w-7 place-items-center rounded-full bg-white text-[#3b6ef0] md:h-9 md:w-9">
                      <Icon name="arrow" size={15} />
                    </span>
                  </a>
                  <a
                    href={ROUTES.nasilUyeOlunur}
                    class="inline-flex items-center gap-2 rounded-buton border border-white/40 px-4 py-1.5 text-sm font-semibold text-white transition hover:bg-white/10 md:px-6 md:py-2.5 md:text-base"
                  >
                    Nasıl Üye Olunur
                  </a>
                </div>
                <p class="mt-1 text-[10px] font-medium text-white/90 md:text-sm">
                  2 Haftalık Ücretsiz Deneyim için kredi kartı gerekmez.
                </p>
              </div>

            </div>
          </div>
        </div>
      </div>

      <!-- ── 2. ALTI ADIMLIK SÜREÇ ──────────────────────────────────────────── -->
      <section class="bg-[#f5f8ff] px-6 py-14 md:px-10 md:py-20">
        <div class="mx-auto max-w-[1400px]">

          <div class="reveal mx-auto max-w-2xl text-center">
            <h2 class="font-baslik text-3xl font-bold text-[#1b2a5b] md:text-4xl">Üyelikten Hedefine Kadar, Adım Adım Süreç</h2>
            <p class="mt-3 text-base text-[#5b6488]">Her aşama planlı, her aşama takip altında.</p>
          </div>

          <!-- Adımlar: anasayfadaki canlı etüt sistemiyle aynı (koyu kart, 2 sütun) -->
          <div class="reveal mt-10 rounded-[8px] bg-lacivert px-6 py-10 md:px-10 md:py-12">
            <div class="grid gap-px sm:grid-cols-2">
              {adimlar.map((a, i) => (
                <div class={`flex items-center gap-3 p-4 sm:gap-4 sm:p-6 ${i < 6 ? 'sm:border-b sm:border-beyaz/10' : ''} ${i % 2 === 0 ? 'sm:border-r sm:border-beyaz/10' : ''}`}>
                  <span class={`grid h-10 w-10 shrink-0 place-items-center rounded-full font-baslik text-sm font-extrabold text-beyaz sm:h-12 sm:w-12 sm:text-base ${a.renk}`}>
                    {a.no}
                  </span>
                  <div class="min-w-0">
                    <p class="font-baslik text-base font-semibold text-beyaz">{a.baslik}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

        </div>
      </section>

      <!-- ── 3. BİR HAFTA NASIL GEÇER ──────────────────────────────────────── -->
      <section class="bg-white px-6 py-14 md:px-10 md:py-20">
        <div class="mx-auto max-w-[1400px]">

          <div class="reveal mx-auto max-w-2xl text-center">
            <h2 class="font-baslik text-3xl font-bold text-[#1b2a5b] md:text-4xl">Öğrencimizin Bir Haftası Nasıl Geçer?</h2>
            <p class="mt-3 text-base text-[#5b6488]">Etüt kulübünde standart bir haftalık akış.</p>
          </div>

          <!-- Masaüstü: yatay çizgi -->
          <div class="reveal mt-14 hidden md:block">
            <div class="relative flex items-start gap-4">
              <!-- Yatay bağlantı çizgisi -->
              <div class="absolute left-[calc(8.33%+20px)] right-[calc(8.33%+20px)] top-5 h-0.5 bg-kenar"></div>

              {haftaAkisi.map((h) => (
                <div class="relative flex flex-1 flex-col items-center text-center">
                  <span class="relative z-10 grid h-10 w-10 shrink-0 place-items-center rounded-full bg-gradient-to-br from-[#6E7CFF] to-[#2D3AAE] text-white shadow-[0_4px_12px_rgba(110,124,255,.35)]">
                    <Icon name={h.ikon} size={16} />
                  </span>
                  <p class="mt-3 font-baslik text-sm font-bold text-[#1b2a5b]">{h.etiket}</p>
                  <p class="mt-1 text-xs leading-relaxed text-[#5b6488]">{h.aciklama}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Mobil: dikey liste -->
          <div class="reveal mt-10 flex flex-col gap-4 md:hidden">
            {haftaAkisi.map((h) => (
              <div class="flex items-start gap-4 rounded-[8px] border border-kenar bg-bulut px-4 py-4">
                <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-gradient-to-br from-[#6E7CFF] to-[#2D3AAE] text-white">
                  <Icon name={h.ikon} size={16} />
                </span>
                <div>
                  <p class="font-baslik text-sm font-bold text-[#1b2a5b]">{h.etiket}</p>
                  <p class="mt-0.5 text-xs text-[#5b6488]">{h.aciklama}</p>
                </div>
              </div>
            ))}
          </div>

          <p class="reveal mt-8 text-center text-xs text-[#5b6488]/70">
            Bu akış temsilidir. Gün, saat ve branş dağılımı döneme göre değişebilir.
          </p>

        </div>
      </section>

      <!-- ── 4. İNSAN + YAPAY ZEKA DENGESİ ────────────────────────────────── -->
      <section class="bg-[#f5f8ff] px-6 py-14 md:px-10 md:py-20">
        <div class="mx-auto max-w-[1400px]">
          <div class="reveal rounded-[8px] bg-lacivert px-6 py-12 md:px-10 md:py-14">

            <p class="mx-auto max-w-2xl text-center font-baslik text-xl font-bold leading-snug text-beyaz md:text-2xl">
              Nerede olursanız olun, içiniz rahat.
            </p>
            <p class="mx-auto mt-4 max-w-xl text-center text-base leading-relaxed text-[#8B96CC]">
              Katılım, çalışma süresi ve haftalık gelişim raporlarıyla çocuğunuzun ders başında olduğunu bilirsiniz.
            </p>

            <div class="mt-10 grid gap-6 md:grid-cols-2 md:gap-8">

              <!-- Gerçek İnsan -->
              <div class="rounded-[8px] border border-kenar bg-beyaz p-6 md:p-8">
                <div class="flex items-center gap-3">
                  <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-mor text-white">
                    <Icon name="users" size={20} />
                  </span>
                  <h3 class="font-baslik text-base font-semibold text-beyaz">Gerçek Öğretmen ve Koç</h3>
                </div>
                <ul class="mt-5 space-y-3">
                  {['Branş öğretmeni canlı etütte yanında.', 'Rehber öğretmenler bireysel koçluk yapar.', 'Yönlendiren, ilgilenen, motive eden öğretmendir.'].map((m) => (
                    <li class="flex items-start gap-2 text-sm leading-relaxed text-[#8B96CC]">
                      <Icon name="check" size={15} class="mt-0.5 shrink-0 text-mor" />
                      {m}
                    </li>
                  ))}
                </ul>
              </div>

              <!-- Yapay Zekâ -->
              <div class="rounded-[8px] border border-kenar bg-beyaz p-6 md:p-8">
                <div class="flex items-center gap-3">
                  <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-turkuaz text-white">
                    <Icon name="cpu" size={20} />
                  </span>
                  <h3 class="font-baslik text-base font-semibold text-beyaz">Yapay Zekâ</h3>
                </div>
                <ul class="mt-5 space-y-3">
                  {['Eksiği bulur, neye nasıl çalışılacağını yönlendirir.', 'Gelişimi ölçer, gerilemeyi erken yakalar.', 'Öğretmene, koça ve veliye anlamlı bilgi taşır.'].map((m) => (
                    <li class="flex items-start gap-2 text-sm leading-relaxed text-[#8B96CC]">
                      <Icon name="check" size={15} class="mt-0.5 shrink-0 text-turkuaz" />
                      {m}
                    </li>
                  ))}
                </ul>
              </div>

            </div>
          </div>
        </div>
      </section>

      <!-- ── 5. VELİ BİLGİLENDİRME DÖNGÜSÜ ───────────────────────────────── -->
      <section class="bg-white px-6 py-14 md:px-10 md:py-20">
        <div class="mx-auto max-w-[1400px]">

          <div class="reveal mx-auto max-w-2xl text-center">
            <h2 class="font-baslik text-3xl font-bold text-[#1b2a5b] md:text-4xl">Süreçten Her Zaman Haberdar Olursunuz</h2>
            <p class="mt-3 text-base text-[#5b6488]">Çocuğunuzun gelişimini düzenli, şeffaf ve anlaşılır raporlarla adım adım takip edersiniz.</p>
          </div>

          <div class="reveal mt-12 grid gap-6 sm:grid-cols-3">
            {veliKartlari.map((k) => (
              <article class="rounded-[8px] border border-[#e7ecf2] bg-white p-6 shadow-[0_10px_30px_rgba(60,80,180,.06)]">
                <span class={`grid h-12 w-12 place-items-center rounded-[8px] text-beyaz ${k.renk}`}>
                  <Icon name={k.ikon} size={22} />
                </span>
                <h3 class="mt-4 font-baslik text-lg font-semibold text-[#1b2a5b]">{k.baslik}</h3>
                <p class="mt-2 text-sm leading-relaxed text-[#5b6488]">{k.aciklama}</p>
              </article>
            ))}
          </div>

        </div>
      </section>

      <!-- ── 6. KAPANIŞ CTA BANDI ──────────────────────────────────────────── -->
      <section class="bg-[#f5f8ff] px-6 pb-14 pt-0 md:px-10 md:pb-20">
        <div class="mx-auto max-w-[1400px]">
          <div class="reveal overflow-hidden rounded-[8px] bg-gradient-to-br from-[#2D3AAE] via-[#3D4EC8] to-[#5060E0] px-6 py-12 text-center md:px-10 md:py-16">

            <h2 class="font-baslik text-2xl font-bold text-white md:text-3xl">
              Süreci İki Hafta Ücretsiz Deneyin
            </h2>
            <p class="mx-auto mt-3 max-w-md text-sm leading-relaxed text-white/80 md:text-base">
              Canlı etütleri, koçluğu ve tüm içerikleri 2 hafta boyunca ücretsiz deneyimleyin.
            </p>

            <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
              <a
                href={UYELIK_URL}
                class="inline-flex items-center gap-2 rounded-buton py-2.5 pl-6 pr-2 text-sm font-semibold shadow-[0_8px_24px_rgba(0,0,0,.20)] transition hover:brightness-95"
                style="background-color: #FFFFFF; color: #2D3AAE;"
              >
                2 Hafta Ücretsiz Dene
                <span class="grid h-8 w-8 place-items-center rounded-full text-white" style="background-color: #3b6ef0;">
                  <Icon name="arrow" size={15} />
                </span>
              </a>
              <a
                href={ROUTES.nasilUyeOlunur}
                class="inline-flex items-center rounded-buton border border-white/40 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-white/10"
              >
                Nasıl Üye Olunur
              </a>
            </div>

          </div>
        </div>
      </section>

      <Footer />
    </div>
  </div>
</Layout>

<style is:global>
  /* === THEME V13: Deep Purple + Navy === */
  .theme-v13 .bg-white      { background-color: #1B2140; }
  .theme-v13 .bg-white\/95  { background-color: rgba(27, 33, 64, 0.97); }
  .theme-v13 .bg-beyaz      { background-color: #1B2140; }
  .theme-v13 .bg-beyaz\/90  { background-color: rgba(27, 33, 64, 0.90); }

  .theme-v13 .text-lacivert       { color: #8B96CC; }
  .theme-v13 .placeholder\:text-gri\/70::placeholder { color: rgba(100, 110, 170, 0.70); }

  .theme-v13 .from-\[\#7c5cfc\] {
    --tw-gradient-from: #6E7CFF var(--tw-gradient-from-position);
    --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(110 124 255 / 0));
  }
  .theme-v13 .from-\[\#7c5cfc\]\/12 {
    --tw-gradient-from: rgb(110 124 255 / 0.12) var(--tw-gradient-from-position);
    --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(110 124 255 / 0));
  }
  .theme-v13 .to-\[\#3b6ef0\] {
    --tw-gradient-to: #2D3AAE var(--tw-gradient-to-position);
  }
  .theme-v13 .to-\[\#3b6ef0\]\/12 {
    --tw-gradient-to: rgb(45 58 174 / 0.12) var(--tw-gradient-to-position);
  }

  .theme-v13 .bg-\[\#ede8ff\]  { background-color: #1B2140; }
  .theme-v13 .bg-\[\#dfe5f5\]  { background-color: #1E2545; }
