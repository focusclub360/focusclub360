---
import Layout from '../layouts/Layout.astro';
import HeroV2 from '../components/HeroV2.astro';
import BrandLine from '../components/BrandLine.astro';
import Approach from '../components/Approach.astro';
import Features from '../components/Features.astro';
import HowItWorks from '../components/HowItWorks.astro';
import BurdenGamification from '../components/BurdenGamification.astro';
import ParentProblems from '../components/ParentProblems.astro';
import RealTeam from '../components/RealTeam.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import NotJustAnd from '../components/NotJustAndFaq.astro';
import Pricing from '../components/Pricing.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { UYELIK_URL, GIRIS_URL, ROUTES } from '../config';

const menu = [
  { ad: 'Kulüpte Neler Var', href: ROUTES.kulupteNelerVar },
  { ad: 'Nasıl Çalışır', href: ROUTES.nasilCalisir },
  { ad: 'Velilere', href: ROUTES.velilere },
  { ad: 'Nasıl Üye Olunur', href: ROUTES.nasilUyeOlunur },
  { ad: 'Rehber', href: ROUTES.rehber },
];
---

<Layout>
  <div class="theme-v4 md:bg-gradient-to-br md:from-[#E0F2FE] md:via-[#ECF6F4] md:to-[#D7F0EC] md:p-4">
    <div class="mx-auto max-w-[1400px] bg-white md:rounded-[8px] md:shadow-[0_30px_80px_rgba(14,165,233,.10)]">

      <div class="sticky top-0 z-50">
        <div class="flex items-center justify-center gap-2 bg-gradient-to-r from-[#0EA5E9] to-[#0D9488] px-4 py-2 text-center text-sm font-medium text-beyaz md:rounded-t-[8px]">
          <Icon name="gift" size={16} />
          Sınırlı süre için ücretsiz 2 hafta deneme fırsatı
        </div>

        <header class="flex items-center justify-between gap-4 bg-white/95 px-6 py-4 backdrop-blur-sm md:px-10">
          <a href="/" class="flex items-center gap-2" aria-label="FocusClub 360">
            <span class="grid h-9 w-9 place-items-center rounded-kart bg-gradient-to-br from-[#0EA5E9] to-[#0D9488] text-beyaz">
              <Icon name="sparkles" size={20} />
            </span>
            <span class="font-baslik text-xl font-extrabold tracking-tight text-[#0F2A43]">FocusClub
              <span class="text-[#0D9488]">360</span>
            </span>
          </a>

          <nav class="hidden items-center gap-7 lg:flex">
            {menu.map((m) => (
              <a href={m.href} class="text-sm font-medium text-[#5a7184] transition hover:text-[#0F2A43]">{m.ad}</a>
            ))}
          </nav>

          <div class="flex items-center gap-2 sm:gap-3">
            <a href={GIRIS_URL} class="hidden text-sm font-semibold text-[#0F2A43] hover:opacity-70 sm:block">Giriş</a>
            <a
              href={UYELIK_URL}
              class="hidden rounded-buton bg-gradient-to-r from-[#0EA5E9] to-[#0D9488] px-5 py-2.5 text-sm font-semibold text-beyaz shadow-[0_8px_20px_rgba(14,165,233,.35)] transition hover:brightness-105 sm:inline-block"
            >2 Hafta Ücretsiz</a>
            <button id="mob-tog" aria-label="Menüyü aç" class="grid h-9 w-9 shrink-0 place-items-center rounded-[8px] border border-kenar text-[#0F2A43] transition hover:bg-bulut lg:hidden">
              <Icon name="menu" size={20} />
            </button>
          </div>
        </header>

        <nav id="mob-nav" class="hidden border-b border-kenar bg-white px-6 pb-5 pt-2 lg:hidden">
          <div class="flex flex-col">
            {menu.map((m) => (
              <a href={m.href} class="mob-link rounded-[8px] px-3 py-2.5 text-sm font-medium text-[#5a7184] transition hover:bg-bulut hover:text-[#0F2A43]">{m.ad}</a>
            ))}
          </div>
          <a
            href={UYELIK_URL}
            class="mt-3 flex items-center justify-center gap-2 rounded-[8px] bg-gradient-to-r from-[#0EA5E9] to-[#0D9488] py-3 text-sm font-semibold text-beyaz"
          >
            2 Hafta Ücretsiz Dene
            <Icon name="arrow" size={16} />
          </a>
        </nav>
      </div>

      <HeroV2 />
      <BrandLine />
      <ParentProblems />
      <Approach />
      <Features />
      <HowItWorks />
      <BurdenGamification />
      <RealTeam />
      <FAQ />
      <Testimonials />
      <NotJustAnd />
      <Pricing />
      <Footer />
    </div>
  </div>
</Layout>

<style is:global>
  /* === THEME V4: Okyanus + Altin === */

  /* Gradient from: #7c5cfc -> #0EA5E9 */
  .theme-v4 .from-\[\#7c5cfc\] {
    --tw-gradient-from: #0EA5E9 var(--tw-gradient-from-position);
    --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(14 165 233 / 0));
  }
  .theme-v4 .from-\[\#7c5cfc\]\/12 {
    --tw-gradient-from: rgb(14 165 233 / 0.12) var(--tw-gradient-from-position);
    --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(14 165 233 / 0));
  }

  /* Gradient to: #3b6ef0 -> #0D9488 */
  .theme-v4 .to-\[\#3b6ef0\] {
    --tw-gradient-to: #0D9488 var(--tw-gradient-to-position);
  }
  .theme-v4 .to-\[\#3b6ef0\]\/12 {
    --tw-gradient-to: rgb(13 148 136 / 0.12) var(--tw-gradient-to-position);
  }

  /* Hero mobile overlay */
  .theme-v4 .bg-\[rgba\(28\,55\,185\,0\.75\)\] {
    background-color: rgba(14, 165, 233, 0.75);
  }

  /* Acik mor arka planlar -> acik teal/mavi */
  .theme-v4 .bg-\[\#ede8ff\]  { background-color: #e0f2fe; }
  .theme-v4 .bg-\[\#dfe5f5\]  { background-color: #d8eef5; }
  .theme-v4 .bg-\[\#e8eaf4\]  { background-color: #e0f0f5; }
  .theme-v4 .bg-\[\#f5f8ff\]  { background-color: #f0f9ff; }

  /* Text renkleri */
  .theme-v4 .text-\[\#1b2a5b\] { color: #0F2A43; }
  .theme-v4 .text-\[\#5b6488\] { color: #5a7184; }
  .theme-v4 .text-\[\#6b76a0\] { color: #6b8395; }
  .theme-v4 .text-\[\#3b6ef0\] { color: #0E7490; }
  .theme-v4 .text-\[\#7c5cfc\] { color: #0E7490; }
  .theme-v4 .hover\:text-\[\#1b2a5b\]:hover { color: #0F2A43; }

  /* Shadow renkleri */
  .theme-v4 .shadow-\[0_8px_20px_rgba\(80\,90\,240\,\.35\)\]  { box-shadow: 0 8px 20px rgba(14,165,233,.35); }
  .theme-v4 .shadow-\[0_8px_20px_rgba\(80\,90\,240\,\.30\)\]  { box-shadow: 0 8px 20px rgba(14,165,233,.30); }
  .theme-v4 .shadow-\[0_12px_30px_rgba\(40\,40\,120\,\.35\)\] { box-shadow: 0 12px 30px rgba(14,165,233,.30); }
  .theme-v4 .shadow-\[0_8px_20px_rgba\(20\,40\,120\,\.35\)\]  { box-shadow: 0 8px 20px rgba(14,165,233,.25); }

  /* Tailwind token override */
  .theme-v4 .bg-mor      { background-color: #0E7490; }
  .theme-v4 .bg-turkuaz  { background-color: #0D9488; }
  .theme-v4 .bg-lacivert { background-color: #0F2A43; }
  .theme-v4 .bg-bulut    { background-color: #F2F8F9; }
  .theme-v4 .text-mor    { color: #0E7490; }
  .theme-v4 .text-turkuaz { color: #0D9488; }

  /* Masaustu hero overlay */
  .theme-v4 .hero-desktop-overlay {
    background: linear-gradient(to right, rgba(14,165,233,0.82) 0%, rgba(14,165,233,0.60) 30%, rgba(14,165,233,0.22) 60%, rgba(14,165,233,0.06) 100%);
  }
</style>

<script>
  const tog = document.getElementById('mob-tog');
  const nav = document.getElementById('mob-nav');
  tog?.addEventListener('click', () => { nav?.classList.toggle('hidden'); });
  document.querySelectorAll('.mob-link').forEach((l) => {
    l.addEventListener('click', () => nav?.classList.add('hidden'));
  });
</script>
