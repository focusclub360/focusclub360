---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import { UYELIK_URL, GIRIS_URL, ROUTES } from '../config';
import heroGorsel from '../assets/kulupte-neler-var-hero.jpg';

const menu = [
  { ad: 'Kulüpte Neler Var', href: ROUTES.kulupteNelerVar },
  { ad: 'Nasıl Çalışır',     href: ROUTES.nasilCalisir    },
  { ad: 'Velilere',          href: ROUTES.velilere         },
  { ad: 'Nasıl Üye Olunur', href: ROUTES.nasilUyeOlunur  },
  { ad: 'Rehber',            href: ROUTES.rehber           },
];

interface Kart {
  renk: string;
  ikon: string;
  baslik: string;
  aciklama: string;
  maddeler: string[];
  extraLink?: { metin: string; href: string };
}

const kartlar: Kart[] = [
  {
    renk: 'bg-turkuaz',
    ikon: 'users',
    baslik: 'Canlı Etüt',
    aciklama: 'Haftanın 4 akşamı, gerçek branş öğretmenleri ile canlı online etüt: ders çalışma, soru çözümü ve deneme çözümü bir arada.',
    maddeler: [
      'Branş bazlı etütler',
      'Öğrenme etüdü, pekiştirme, canlı soru çözüm akışıyla ilerleyen düzen.',
      'Öğretmenle anlık etkileşim ve aynı anda çalışan bir grup.',
    ],
  },
  {
    renk: 'bg-mercan',
    ikon: 'flask',
    baslik: 'Canlı Soru Çözüm',
    aciklama: 'Takıldığı soruyu yalnız bırakmadan, gerçek branş öğretmeniyle canlı çözen bir öğrenci. Sorular ilgili branş öğretmeninin yardımıyla canlı olarak çözülür.',
    maddeler: [
      'Branş öğretmeniyle canlı, anında soru çözüm seansları.',
      'Yanlış ve eksiklerin anında giderilmesi.',
      'Deneme ve test sonrası canlı çözüm desteği.',
    ],
  },
  {
    renk: 'bg-mor',
    ikon: 'target',
    baslik: 'Gerçek Koçluk',
    aciklama: 'Dijital koçluğun ötesinde, gerçek rehber öğretmenle bireysel ve canlı koçluk. Çocuğunuzla yakından ilgilenen, yönlendiren gerçek rehber öğretmenler.',
    maddeler: [
      'Gerçek rehber öğretmenle bireysel, canlı koçluk görüşmeleri.',
      'Kişiye özel hedef belirleme ve motivasyon takibi.',
      'Gerileme ve düşüşlerde erken müdahale.',
    ],
  },
  {
    renk: 'bg-amber',
    ikon: 'cpu',
    baslik: 'Yapay Zekâ Takibi',
    aciklama: 'Kayıttan LGS sınavına kadar tüm süreci takip eden akıllı katman. Yapay zekâ sadece rapor üretmez; eksiği bulur, neye nasıl çalışılacağını yönlendirir, riski erken yakalar ve gerçek öğretmenlere taşır.',
    maddeler: [
      'Eksik tespiti ve kişiye özel çalışma yönlendirmesi.',
      'Tam öğrenme ve akıllı tekrar ile sürekli gelişim ölçümü.',
      'Gerileme ve risklerin erken yakalanması.',
    ],
  },
  {
    renk: 'bg-mavi',
    ikon: 'video',
    baslik: 'Dijital Ders İçerikleri',
    aciklama: 'Canlı yapının yanında, istediği an erişebileceği zengin bir dijital içerik arşivi. LGS\'nin tüm branşlarında anlatım, soru çözüm ve denemeler.',
    maddeler: [
      'Tüm branşlarda video anlatım ve video çözümlü sorular.',
      'Dijital ders dökümanları ve çalışma kaynakları.',
      'Deneme sınavları ve test çözümleri.',
    ],
  },
  {
    renk: 'bg-[#06B6D4]',
    ikon: 'mail',
    baslik: 'Deneme Kulübü',
    aciklama: 'Birinci ve ikinci dönem ayrı ayrı olmak üzere adreslerinize basılı deneme paketi gönderilecektir.',
    maddeler: [
      'Birinci ve ikinci döneme özel iki ayrı basılı deneme paketi.',
      'Paketler doğrudan adresinize kargolanır.',
      'Gerçek sınav formatında deneme deneyimi.',
    ],
  },
  {
    renk: 'bg-mint',
    ikon: 'bell',
    baslik: 'Veli Raporlama',
    aciklama: 'Çocuğunuzun etüt içi aktivitesi, ders durumu ve kişisel gelişimi düzenli olarak sizinle paylaşılır. Sürecin neresinde olduğunu net biçimde görürsünüz.',
    maddeler: [
      'Veliye düzenli, anlaşılır bilgilendirme: haftalık rapor, aylık değerlendirme.',
      'Katılım, çalışma süresi ve gelişim özetleri.',
      'Bildirim ve raporların doğrudan veliye iletilmesi.',
    ],
    extraLink: { metin: 'Veliler için detaylı bilgi', href: ROUTES.velilere },
  },
];

const adimlar = [
  { no: 1, baslik: 'Öğrenme Etüdü',     aciklama: 'Konu, branş öğretmeni gözetiminde çalışılır.'  },
  { no: 2, baslik: 'Pekiştirme ve Test', aciklama: 'Öğrenilen konu sorularla pekiştirilir.'         },
  { no: 3, baslik: 'Canlı Soru Çözüm',  aciklama: 'Eksik ve yanlışlar canlı olarak çözülür.'       },
];
---

<Layout
  title="Kulüpte Neler Var — FocusClub 360"
  description="FocusClub 360 üyeliğiyle çocuğunuz gerçek branş öğretmenleri ve koçlarla, yapay zekâ takibiyle LGS'ye hazırlanır. Üyelikte tam olarak neler olduğunu görün."
>
  <div class="theme-v13 bg-[#131629] md:bg-[#131629] md:p-4">
    <div class="mx-auto max-w-[1400px] bg-white md:rounded-[8px] md:shadow-[0_30px_80px_rgba(110,124,255,.18)]">

      <!-- Sticky header -->
      <div class="sticky top-0 z-50">
        <div class="flex items-center justify-center gap-2 bg-gradient-to-r from-[#2D3AAE] to-[#5060E0] px-4 py-2 text-center text-sm font-medium text-beyaz md:rounded-t-[8px]">
          <Icon name="gift" size={16} />
          Ücretsiz İki Hafta Deneyim Fırsatı
        </div>

        <header class="flex items-center justify-between gap-4 px-6 py-3 backdrop-blur-sm md:py-4 md:px-10" style="background-color: rgba(27,33,64,0.97);">
          <a href="/" class="flex items-center" aria-label="FocusClub 360"><img src="/FocusClub360_logoF_navy.png" alt="FocusClub 360" class="h-[54px] w-auto md:h-[72px]" /></a>

          <nav class="hidden items-center gap-7 lg:flex">
            {menu.map((m) => (
              <a
                href={m.href}
                class={`text-sm transition ${m.href === ROUTES.kulupteNelerVar ? 'font-semibold text-[#FFFFFF]' : 'font-medium text-[#8B96CC] hover:text-[#FFFFFF]'}`}
              >
                {m.ad}
              </a>
            ))}
          </nav>

          <div class="flex items-center gap-2 sm:gap-3">
            <a href={GIRIS_URL} class="hidden text-sm font-semibold text-[#FFFFFF] hover:opacity-70 sm:block">Giriş</a>
            <a
              href={UYELIK_URL}
              class="hidden rounded-buton bg-gradient-to-r from-[#6E7CFF] to-[#2D3AAE] px-5 py-2.5 text-sm font-semibold text-beyaz shadow-[0_8px_20px_rgba(110,124,255,.40)] transition hover:brightness-110 sm:inline-block"
            >2 Hafta Ücretsiz</a>
            <button id="mob-tog" aria-label="Menüyü aç" class="grid h-9 w-9 shrink-0 place-items-center rounded-[8px] border border-kenar text-[#FFFFFF] transition hover:bg-bulut focus:outline-none active:bg-[#1E2848] lg:hidden" style="-webkit-tap-highlight-color: transparent; background-color: #1B2140; -webkit-appearance: none; appearance: none;">
              <Icon name="menu" size={20} />
            </button>
          </div>
        </header>

        <nav id="mob-nav" class="hidden border-b border-kenar px-6 pb-5 pt-2 lg:hidden" style="background-color: #1B2140;">
          <div class="flex flex-col">
            {menu.map((m) => (
              <a href={m.href} class="mob-link rounded-[8px] px-3 py-2.5 text-sm font-medium text-[#8B96CC] transition hover:bg-bulut hover:text-[#FFFFFF]">{m.ad}</a>
            ))}
            <a href={GIRIS_URL} class="mob-link rounded-[8px] px-3 py-2.5 text-sm font-medium text-[#8B96CC] transition hover:bg-bulut hover:text-[#FFFFFF]">Giriş</a>
          </div>
          <a
            href={UYELIK_URL}
            class="mt-3 flex items-center justify-center gap-2 rounded-[8px] bg-gradient-to-r from-[#6E7CFF] to-[#2D3AAE] py-3 text-sm font-semibold text-beyaz"
          >
            2 Hafta Ücretsiz Dene
            <Icon name="arrow" size={16} />
          </a>
        </nav>
      </div>

      <!-- 1. Hero -->
      <div class="flex min-h-[calc(100svh-8rem)] flex-col md:min-h-[calc(100vh-9rem)]">
        <div class="flex min-h-0 flex-1 flex-col px-6 pb-4 md:px-10 md:pb-6">

          <!-- Badge -->
          <div class="pb-2 pt-3 md:pb-3 md:pt-4">
            <span class="flex w-full items-center gap-1 rounded-md bg-[#ede8ff] px-2.5 py-1 text-[11px] font-semibold text-[#3b6ef0] md:inline-flex md:w-auto md:gap-1.5 md:bg-gradient-to-r md:from-[#7c5cfc]/12 md:to-[#3b6ef0]/12 md:px-3 md:py-1 md:text-sm">
              <Icon name="star" size={12} class="text-[#7c5cfc] md:size-[14px]" />
              Kulüpte Neler Var?
            </span>
          </div>

          <!-- Banner -->
          <div class="relative min-h-0 flex-1 overflow-hidden rounded-[8px]">
            <Image
              src={heroGorsel}
              alt="FocusClub 360 etüt kulübü"
              widths={[768, 1280, 1600]}
              sizes="100vw"
              class="absolute inset-0 h-full w-full object-cover object-center"
              loading="eager"
            />
            <div class="absolute inset-0 md:hidden" style="background-color: rgba(19,22,41,0.75);"></div>
            <div class="absolute inset-0 hidden md:block" style="background: linear-gradient(to right, rgba(19,22,41,0.83) 0%, rgba(19,22,41,0.38) 45%, rgba(19,22,41,0.09) 100%);"></div>

            <!-- İçerik -->
            <div class="absolute inset-0 z-10 flex flex-col justify-evenly px-5 py-4 md:px-10 md:py-10">

              <div class="max-w-[90%] md:max-w-2xl">
                <h1 class="font-baslik text-xl font-extrabold tracking-tight text-white md:text-3xl lg:text-[2.4rem]" style="line-height: 1.18;">
                  Sizin ve Çocuğunuzun İhtiyacı Olan Tüm Sistem Bu Üyeliğin İçinde
                </h1>
                <ul class="mt-3 space-y-1 text-xs leading-snug text-white/85 md:mt-4 md:space-y-1.5 md:text-sm">
                  <li>Öğrenmeyi öğreten <strong class="font-semibold text-white">Konu Çalışma Etütleri</strong></li>
                  <li>Çalışma alışkanlığı kazandıran <strong class="font-semibold text-white">Uygulama Etütleri</strong></li>
                  <li>Odaklanma becerisini artıran <strong class="font-semibold text-white">Sınav Günü Uygulaması</strong></li>
                  <li>Dikkat eksikliğini azaltan <strong class="font-semibold text-white">Kişiye Özgü Tam Öğrenme İçerikleri</strong></li>
                  <li>Okul başarısını destekleyen <strong class="font-semibold text-white">MEB İçerikleri Analizi Uygulaması</strong></li>
                  <li>Öz-düzenleme becerisini ve motivasyonu artıran <strong class="font-semibold text-white">Kişiye Özel Eğitim Koçluğu Hizmeti</strong></li>
                  <li>Özgüveni pekiştiren <strong class="font-semibold text-white">Uzman Öğretmen Desteği</strong></li>
                  <li>Şeffaf ve anlık raporlama sağlayan <strong class="font-semibold text-white">İlerletici Geribildirim Sistemi</strong></li>
                  <li>Velilerimize rehberlik eden ve <strong class="font-semibold text-white">Yetkin Veli, Etkin Çözüm Modeli</strong></li>
                </ul>
              </div>

              <div>
                <div class="flex flex-wrap gap-2 md:gap-3">
                  <a
                    href={UYELIK_URL}
                    class="inline-flex items-center gap-2 rounded-buton bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] py-1.5 pl-4 pr-1.5 text-sm font-semibold text-beyaz shadow-[0_12px_30px_rgba(40,40,120,.35)] transition hover:brightness-105 md:gap-3 md:py-2.5 md:pl-6 md:pr-2.5 md:text-base"
                  >
                    2 Hafta Ücretsiz Dene
                    <span class="grid h-7 w-7 place-items-center rounded-full bg-white text-[#3b6ef0] md:h-9 md:w-9">
                      <Icon name="arrow" size={15} />
                    </span>
                  </a>
                  <a
                    href={ROUTES.nasilUyeOlunur}
                    class="inline-flex items-center gap-2 rounded-buton border border-white/40 px-4 py-1.5 text-sm font-semibold text-white transition hover:bg-white/10 md:px-6 md:py-2.5 md:text-base"
                  >
                    Nasıl Üye Olunur
                  </a>
                </div>
                <p class="mt-1 text-[10px] font-medium text-white/90 md:text-sm">
                  2 Haftalık Ücretsiz Deneyim için kredi kartı gerekmez.
                </p>
              </div>

            </div>
          </div>
        </div>
      </div>

      <!-- 2. Beş Ana Kolon -->
      <section class="bg-[#f5f8ff] px-6 pb-14 pt-12 md:px-10 md:pb-20 md:pt-16">
        <div class="mx-auto max-w-[1400px]">
          <div class="reveal mx-auto max-w-2xl text-center">
            <h2 class="font-baslik text-3xl font-bold text-[#1b2a5b] md:text-4xl">Üyelikte Tam Olarak Neler Var?</h2>
            <p class="mt-3 text-base text-[#5b6488]">FocusClub 360, çocuğunuzu düzenli ders çalıştıran online ve canlı bir sistemdir. Gerçek branş öğretmenleri ve gerçek rehber öğretmenlerle, baştan sona yapay zekâ takibiyle LGS'ye hazırlar ve ders çalıştırma yükünü siz velilerden alır.</p>
          </div>

          <div class="mt-10 space-y-4 md:mt-12 md:space-y-5">
            {kartlar.map((k) => (
              <article class="reveal group rounded-[8px] border border-[#e7ecf2] bg-white p-6 shadow-[0_10px_30px_rgba(60,80,180,.06)] transition duration-300 hover:shadow-[0_20px_45px_rgba(60,80,180,.10)] md:p-8">
                <div class="grid gap-6 lg:grid-cols-[2fr_3fr] lg:gap-10">
                  <!-- Sol: ikon + başlık + açıklama -->
                  <div>
                    <span class={`grid h-14 w-14 place-items-center rounded-[8px] text-beyaz transition duration-300 group-hover:scale-105 ${k.renk}`}>
                      <Icon name={k.ikon} size={26} />
                    </span>
                    <h3 class="mt-4 font-baslik text-xl font-bold leading-snug text-[#1b2a5b]">{k.baslik}</h3>
                    <p class="mt-2 text-sm leading-relaxed text-[#5b6488] md:text-base">{k.aciklama}</p>
                    {k.extraLink && (
                      <a href={k.extraLink.href} class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-[#3b6ef0] transition hover:gap-2">
                        {k.extraLink.metin}
                        <Icon name="arrow" size={14} />
                      </a>
                    )}
                  </div>
                  <!-- Sağ: madde listesi -->
                  <div class="flex flex-col justify-center">
                    <p class="text-xs font-semibold uppercase tracking-widest text-[#5b6488]">Neyi Kapsar</p>
                    <ul class="mt-3 space-y-2.5">
                      {k.maddeler.map((m) => (
                        <li class="flex items-start gap-2.5">
                          <span class={`mt-0.5 grid h-5 w-5 shrink-0 place-items-center rounded-full text-beyaz ${k.renk}`}>
                            <Icon name="check" size={11} />
                          </span>
                          <span class="text-sm leading-relaxed text-[#1b2a5b]">{m}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- 3. İçerik Envanteri -->
      <section class="bg-white px-6 py-6 md:px-10 md:py-8">
        <div class="mx-auto max-w-[1400px]">
          <div class="reveal rounded-[8px] bg-lacivert px-6 py-12 md:px-10 md:py-14">
            <p class="text-center font-baslik text-xl font-bold text-beyaz md:text-2xl">Akıllı Öğretim Ekosistemi</p>
            <div class="mt-10 grid grid-cols-2 gap-6 sm:grid-cols-3 md:gap-10">
              <div class="text-center">
                <p class="font-baslik text-4xl font-extrabold text-beyaz md:text-5xl">
                  <span class="count-up" data-target="5920">0</span><span class="font-extrabold text-beyaz">+</span>
                </p>
                <p class="mt-2 text-sm text-beyaz/60">dakika ders anlatımı</p>
              </div>
              <div class="text-center">
                <p class="font-baslik text-4xl font-extrabold text-beyaz md:text-5xl">
                  <span class="count-up" data-target="4440">0</span><span class="font-extrabold text-beyaz">+</span>
                </p>
                <p class="mt-2 text-sm text-beyaz/60">dakika soru çözüm</p>
              </div>
              <div class="col-span-2 text-center sm:col-span-1">
                <p class="font-baslik text-4xl font-extrabold text-beyaz md:text-5xl">
                  <span class="count-up" data-target="10134">0</span><span class="font-extrabold text-beyaz">+</span>
                </p>
                <p class="mt-2 text-sm text-beyaz/60">video çözümlü soru</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- 4. Örnek Etüt Akışı -->
      <section class="bg-[#f5f8ff] px-6 py-14 md:px-10 md:py-20">
        <div class="mx-auto max-w-[1400px]">
          <div class="reveal mx-auto max-w-2xl text-center">
            <h2 class="font-baslik text-3xl font-bold text-[#1b2a5b] md:text-4xl">Bir Etüt Akşamı Nasıl İlerler?</h2>
            <p class="mt-3 text-base text-[#5b6488]">Her etüt aynı sağlam düzende akar.</p>
          </div>

          <div class="reveal mt-10 md:mt-12">
            <!-- Desktop: yatay akış -->
            <div class="hidden items-stretch gap-3 md:flex">
              {adimlar.map((a, i) => (
                <>
                  <div class="flex flex-1 flex-col rounded-[8px] border border-kenar bg-white p-6 shadow-kucuk">
                    <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-gradient-to-br from-[#7c5cfc] to-[#3b6ef0] font-baslik text-sm font-bold text-beyaz">{a.no}</span>
                    <h3 class="mt-4 font-baslik text-base font-semibold text-[#1b2a5b]">{a.baslik}</h3>
                    <p class="mt-1 flex-1 text-sm text-[#5b6488]">{a.aciklama}</p>
                  </div>
                  {i < adimlar.length - 1 && (
                    <div class="flex items-center">
                      <Icon name="arrow" size={22} class="shrink-0 text-[#7c5cfc]" />
                    </div>
                  )}
                </>
              ))}
            </div>

            <!-- Mobil: dikey akış -->
            <div class="flex flex-col gap-2 md:hidden">
              {adimlar.map((a, i) => (
                <>
                  <div class="rounded-[8px] border border-kenar bg-white p-5 shadow-kucuk">
                    <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-[#7c5cfc] to-[#3b6ef0] font-baslik text-sm font-bold text-beyaz">{a.no}</span>
                    <h3 class="mt-3 font-baslik text-sm font-semibold text-[#1b2a5b]">{a.baslik}</h3>
                    <p class="mt-1 text-xs text-[#5b6488]">{a.aciklama}</p>
                  </div>
                  {i < adimlar.length - 1 && (
                    <div class="flex justify-center py-0.5">
                      <Icon name="chevron" size={18} class="text-[#7c5cfc]" />
                    </div>
                  )}
                </>
              ))}
            </div>

            <p class="mt-6 text-center text-xs text-[#5b6488]">
              Bu akış temsilidir. Gün, saat ve branş dağılımı döneme göre değişebilir.
            </p>
          </div>
        </div>
      </section>

      <!-- 5. İnsan + Yapay Zekâ -->
      <section class="bg-white px-6 py-6 md:px-10 md:py-8">
        <div class="mx-auto max-w-[1400px]">
          <div class="reveal rounded-[8px] bg-lacivert px-6 py-12 md:px-10 md:py-14">
            <p class="mx-auto max-w-2xl text-center font-baslik text-xl font-bold leading-relaxed text-beyaz md:text-2xl">
              Sadece bir uygulama değil; çocuğunuzun yanında gerçek branş ve rehber öğretmenleri ve onları baştan sona takip eden akıllı bir sistem.
            </p>
            <div class="mt-10 grid gap-5 md:grid-cols-2 md:gap-6">
              <div class="rounded-[8px] bg-beyaz/5 p-6">
                <div class="flex items-center gap-2.5">
                  <span class="grid h-8 w-8 place-items-center rounded-full bg-turkuaz text-beyaz">
                    <Icon name="users" size={16} />
                  </span>
                  <h3 class="font-baslik text-base font-semibold text-beyaz">Gerçek Branş Öğretmenleri ve Rehber Öğretmenler</h3>
                </div>
                <ul class="mt-4 space-y-3">
                  {['Branş öğretmenleri canlı etütte yanında.', 'Rehber öğretmenler bireysel koçluk yapar.', 'Karar veren, yönlendiren, ilgilenen öğretmenlerdir.'].map((m) => (
                    <li class="flex items-start gap-2">
                      <Icon name="check" size={14} class="mt-0.5 shrink-0 text-turkuaz" />
                      <span class="text-sm text-beyaz/80">{m}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="rounded-[8px] bg-beyaz/5 p-6">
                <div class="flex items-center gap-2.5">
                  <span class="grid h-8 w-8 place-items-center rounded-full bg-mor text-beyaz">
                    <Icon name="cpu" size={16} />
                  </span>
                  <h3 class="font-baslik text-base font-semibold text-beyaz">Yapay Zekâ</h3>
