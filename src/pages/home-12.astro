---
import Layout from '../layouts/Layout.astro';
import HeroV2 from '../components/HeroV2.astro';
import BrandLine from '../components/BrandLine.astro';
import Approach from '../components/Approach.astro';
import Features from '../components/Features.astro';
import HowItWorks from '../components/HowItWorks.astro';
import BurdenGamification from '../components/BurdenGamification.astro';
import ParentProblems from '../components/ParentProblems.astro';
import RealTeam from '../components/RealTeam.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import NotJustAnd from '../components/NotJustAndFaq.astro';
import Pricing from '../components/Pricing.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { UYELIK_URL, GIRIS_URL, ROUTES } from '../config';

const menu = [
  { ad: 'Kulüpte Neler Var', href: ROUTES.kulupteNelerVar },
  { ad: 'Nasıl Çalışır', href: ROUTES.nasilCalisir },
  { ad: 'Velilere', href: ROUTES.velilere },
  { ad: 'Nasıl Üye Olunur', href: ROUTES.nasilUyeOlunur },
  { ad: 'Rehber', href: ROUTES.rehber },
];
---

<Layout>
  <div class="theme-v12 bg-[#121212] md:bg-[#121212] md:p-4">
    <div class="mx-auto max-w-[1400px] bg-white md:rounded-[8px] md:shadow-[0_30px_80px_rgba(212,175,55,.14)]">

      <div class="sticky top-0 z-50">
        <div class="flex items-center justify-center gap-2 bg-gradient-to-r from-[#7A6010] to-[#B8960C] px-4 py-2 text-center text-sm font-medium text-beyaz md:rounded-t-[8px]">
          <Icon name="gift" size={16} />
          Sınırlı süre için ücretsiz 2 hafta deneme fırsatı
        </div>

        <header class="flex items-center justify-between gap-4 bg-white/95 px-6 py-4 backdrop-blur-sm md:px-10">
          <a href="/" class="flex items-center gap-2" aria-label="FocusClub 360">
            <span class="grid h-9 w-9 place-items-center rounded-kart bg-gradient-to-br from-[#D4AF37] to-[#8B6914] text-[#121212]">
              <Icon name="sparkles" size={20} />
            </span>
            <span class="font-baslik text-xl font-extrabold tracking-tight text-[#FFFFFF]">FocusClub
              <span class="text-[#D4AF37]">360</span>
            </span>
          </a>

          <nav class="hidden items-center gap-7 lg:flex">
            {menu.map((m) => (
              <a href={m.href} class="text-sm font-medium text-[#B8A878] transition hover:text-[#FFFFFF]">{m.ad}</a>
            ))}
          </nav>

          <div class="flex items-center gap-2 sm:gap-3">
            <a href={GIRIS_URL} class="hidden text-sm font-semibold text-[#FFFFFF] hover:opacity-70 sm:block">Giriş</a>
            <a
              href={UYELIK_URL}
              class="hidden rounded-buton bg-gradient-to-r from-[#D4AF37] to-[#8B6914] px-5 py-2.5 text-sm font-semibold text-[#121212] shadow-[0_8px_20px_rgba(212,175,55,.40)] transition hover:brightness-105 sm:inline-block"
            >2 Hafta Ücretsiz</a>
            <button id="mob-tog" aria-label="Menüyü aç" class="grid h-9 w-9 shrink-0 place-items-center rounded-[8px] border border-kenar text-[#FFFFFF] transition hover:bg-bulut lg:hidden">
              <Icon name="menu" size={20} />
            </button>
          </div>
        </header>

        <nav id="mob-nav" class="hidden border-b border-kenar bg-white px-6 pb-5 pt-2 lg:hidden">
          <div class="flex flex-col">
            {menu.map((m) => (
              <a href={m.href} class="mob-link rounded-[8px] px-3 py-2.5 text-sm font-medium text-[#B8A878] transition hover:bg-bulut hover:text-[#FFFFFF]">{m.ad}</a>
            ))}
          </div>
          <a
            href={UYELIK_URL}
            class="mt-3 flex items-center justify-center gap-2 rounded-[8px] bg-gradient-to-r from-[#D4AF37] to-[#8B6914] py-3 text-sm font-semibold text-[#121212]"
          >
            2 Hafta Ücretsiz Dene
            <Icon name="arrow" size={16} />
          </a>
        </nav>
      </div>

      <HeroV2 />
      <BrandLine />
      <ParentProblems />
      <Approach />
      <Features />
      <HowItWorks />
      <BurdenGamification />
      <RealTeam />
      <FAQ />
      <Testimonials />
      <NotJustAnd />
      <Pricing />
      <Footer />
    </div>
  </div>
</Layout>

<style is:global>
  /* === THEME V12: Charcoal + Gold === */

  /* Karanlik arka plan override */
  .theme-v12 .bg-white      { background-color: #1C1C1C; }
  .theme-v12 .bg-white\/95  { background-color: rgba(28, 28, 28, 0.97); }
  .theme-v12 .bg-beyaz      { background-color: #1C1C1C; }
  .theme-v12 .bg-beyaz\/90  { background-color: rgba(28, 28, 28, 0.90); }

  /* Input/koyu metin tokenlarini acik renge cevir */
  .theme-v12 .text-lacivert       { color: #C8B878; }
  .theme-v12 .placeholder\:text-gri\/70::placeholder { color: rgba(140, 120, 70, 0.70); }

  /* Gradient from: #7c5cfc -> #D4AF37 */
  .theme-v12 .from-\[\#7c5cfc\] {
    --tw-gradient-from: #D4AF37 var(--tw-gradient-from-position);
    --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(212 175 55 / 0));
  }
  .theme-v12 .from-\[\#7c5cfc\]\/12 {
    --tw-gradient-from: rgb(212 175 55 / 0.12) var(--tw-gradient-from-position);
    --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(212 175 55 / 0));
  }

  /* Gradient to: #3b6ef0 -> #8B6914 */
  .theme-v12 .to-\[\#3b6ef0\] {
    --tw-gradient-to: #8B6914 var(--tw-gradient-to-position);
  }
  .theme-v12 .to-\[\#3b6ef0\]\/12 {
    --tw-gradient-to: rgb(139 105 20 / 0.12) var(--tw-gradient-to-position);
  }

  /* Hero mobile overlay - charcoal */
  .theme-v12 .bg-\[rgba\(28\,55\,185\,0\.75\)\] {
    background-color: rgba(18, 18, 18, 0.88);
  }

  /* Bolum arka planlari -> karanlik tonlar */
  .theme-v12 .bg-\[\#ede8ff\]  { background-color: #1C1C1C; }
  .theme-v12 .bg-\[\#dfe5f5\]  { background-color: #221E12; }
  .theme-v12 .bg-\[\#e8eaf4\]  { background-color: #201C10; }
  .theme-v12 .bg-\[\#f5f8ff\]  { background-color: #181410; }

  /* Text renkleri */
  .theme-v12 .text-\[\#1b2a5b\]              { color: #FFFFFF; }
  .theme-v12 .text-\[\#5b6488\]              { color: #B8A878; }
  .theme-v12 .text-\[\#6b76a0\]              { color: #8A7E5A; }
  .theme-v12 .text-\[\#3b6ef0\]              { color: #D4AF37; }
  .theme-v12 .text-\[\#7c5cfc\]              { color: #D4AF37; }
  .theme-v12 .hover\:text-\[\#1b2a5b\]:hover { color: #FFFFFF; }

  /* Shadow renkleri */
  .theme-v12 .shadow-\[0_8px_20px_rgba\(80\,90\,240\,\.35\)\]  { box-shadow: 0 8px 20px rgba(212,175,55,.35); }
  .theme-v12 .shadow-\[0_8px_20px_rgba\(80\,90\,240\,\.30\)\]  { box-shadow: 0 8px 20px rgba(212,175,55,.30); }
  .theme-v12 .shadow-\[0_12px_30px_rgba\(40\,40\,120\,\.35\)\] { box-shadow: 0 12px 30px rgba(212,175,55,.22); }
  .theme-v12 .shadow-\[0_8px_20px_rgba\(20\,40\,120\,\.35\)\]  { box-shadow: 0 8px 20px rgba(212,175,55,.18); }

  /* Tailwind token override */
  .theme-v12 .bg-mor       { background-color: #D4AF37; }
  .theme-v12 .bg-turkuaz   { background-color: #B8960C; }
  .theme-v12 .bg-lacivert  { background-color: #121212; }
  .theme-v12 .bg-bulut     { background-color: #252010; }
  .theme-v12 .border-kenar { border-color: #2E2A1A; }
  .theme-v12 .text-mor     { color: #D4AF37; }
  .theme-v12 .text-turkuaz { color: #E8C84A; }

  /* Masaustu hero overlay - charcoal */
  .theme-v12 .hero-desktop-overlay {
    background: linear-gradient(to right, rgba(18,18,18,0.92) 0%, rgba(18,18,18,0.74) 30%, rgba(18,18,18,0.34) 60%, rgba(18,18,18,0.06) 100%);
  }
</style>

<script>
  const tog = document.getElementById('mob-tog');
  const nav = document.getElementById('mob-nav');
  tog?.addEventListener('click', () => { nav?.classList.toggle('hidden'); });
  document.querySelectorAll('.mob-link').forEach((l) => {
    l.addEventListener('click', () => nav?.classList.add('hidden'));
  });
</script>
