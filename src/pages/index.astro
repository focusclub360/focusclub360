---
import Layout from '../layouts/Layout.astro';
import HeroV2 from '../components/HeroV2.astro';
import BrandLine from '../components/BrandLine.astro';
import Approach from '../components/Approach.astro';
import Features from '../components/Features.astro';
import HowItWorks from '../components/HowItWorks.astro';
import BurdenGamification from '../components/BurdenGamification.astro';
import ParentProblems from '../components/ParentProblems.astro';
import RealTeam from '../components/RealTeam.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import NotJustAnd from '../components/NotJustAndFaq.astro';
import Pricing from '../components/Pricing.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { UYELIK_URL, GIRIS_URL, ROUTES } from '../config';

const menu = [
  { ad: 'Kulüpte Neler Var', href: ROUTES.kulupteNelerVar },
  { ad: 'Nasıl Çalışır', href: ROUTES.nasilCalisir },
  { ad: 'Velilere', href: ROUTES.velilere },
  { ad: 'Nasıl Üye Olunur', href: ROUTES.nasilUyeOlunur },
  { ad: 'Rehber', href: ROUTES.rehber },
];
---

<Layout>
  <div class="md:bg-gradient-to-br md:from-[#e9e3ff] md:via-[#eef1ff] md:to-[#d9e9ff] md:p-4">
    <div class="mx-auto max-w-[1400px] bg-white md:rounded-[8px] md:shadow-[0_30px_80px_rgba(60,80,180,.18)]">

      <!-- Sticky header -->
      <div class="sticky top-0 z-50">
        <!-- Bilgilendirme şeridi -->
        <div class="flex items-center justify-center gap-2 bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] px-4 py-2 text-center text-sm font-medium text-beyaz md:rounded-t-[8px]">
          <Icon name="gift" size={16} />
          Sınırlı süre için ücretsiz 2 hafta deneme fırsatı
        </div>

        <!-- Üst menü -->
        <header class="flex items-center justify-between gap-4 bg-white/95 px-6 py-4 backdrop-blur-sm md:px-10">
          <a href="/" class="flex items-center gap-2" aria-label="FocusClub 360">
            <span class="grid h-9 w-9 place-items-center rounded-kart bg-gradient-to-br from-[#7c5cfc] to-[#3b6ef0] text-beyaz">
              <Icon name="sparkles" size={20} />
            </span>
            <span class="font-baslik text-xl font-extrabold tracking-tight text-[#1b2a5b]">FocusClub
              <span class="bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] bg-clip-text text-transparent">360</span>
            </span>
          </a>

          <nav class="hidden items-center gap-7 lg:flex">
            {menu.map((m) => (
              <a href={m.href} class="text-sm font-medium text-[#5b6488] transition hover:text-[#1b2a5b]">{m.ad}</a>
            ))}
          </nav>

          <div class="flex items-center gap-2 sm:gap-3">
            <a href={GIRIS_URL} class="hidden text-sm font-semibold text-[#1b2a5b] hover:opacity-70 sm:block">Giriş</a>
            <a
              href={UYELIK_URL}
              class="hidden rounded-buton bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] px-5 py-2.5 text-sm font-semibold text-beyaz shadow-[0_8px_20px_rgba(80,90,240,.35)] transition hover:brightness-105 sm:inline-block"
            >2 Hafta Ücretsiz</a>
            <button id="mob-tog" aria-label="Menüyü aç" class="grid h-9 w-9 shrink-0 place-items-center rounded-[8px] border border-kenar text-[#1b2a5b] transition hover:bg-bulut lg:hidden">
              <Icon name="menu" size={20} />
            </button>
          </div>
        </header>

        <!-- Mobil nav -->
        <nav id="mob-nav" class="hidden border-b border-kenar bg-white px-6 pb-5 pt-2 lg:hidden">
          <div class="flex flex-col">
            {menu.map((m) => (
              <a href={m.href} class="mob-link rounded-[8px] px-3 py-2.5 text-sm font-medium text-[#5b6488] transition hover:bg-bulut hover:text-[#1b2a5b]">{m.ad}</a>
            ))}
          </div>
          <a
            href={UYELIK_URL}
            class="mt-3 flex items-center justify-center gap-2 rounded-[8px] bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] py-3 text-sm font-semibold text-beyaz"
          >
            2 Hafta Ücretsiz Dene
            <Icon name="arrow" size={16} />
          </a>
        </nav>
      </div>

      <HeroV2 />
      <BrandLine />
      <ParentProblems />
      <Approach />
      <Features />
      <HowItWorks />
      <BurdenGamification />
      <RealTeam />
      <FAQ />
      <Testimonials />
      <NotJustAnd />
      <Pricing />
      <Footer />
    </div>
  </div>
</Layout>

<script>
  const tog = document.getElementById('mob-tog');
  const nav = document.getElementById('mob-nav');
  tog?.addEventListener('click', () => { nav?.classList.toggle('hidden'); });
  document.querySelectorAll('.mob-link').forEach((l) => {
    l.addEventListener('click', () => nav?.classList.add('hidden'));
  });
</script>
