---
import Layout from '../layouts/Layout.astro';
import HeroV2 from '../components/HeroV2.astro';
import BrandLine from '../components/BrandLine.astro';
import Approach from '../components/Approach.astro';
import Features from '../components/Features.astro';
import HowItWorks from '../components/HowItWorks.astro';
import BurdenGamification from '../components/BurdenGamification.astro';
import ParentProblems from '../components/ParentProblems.astro';
import RealTeam from '../components/RealTeam.astro';
import FAQ from '../components/FAQ.astro';
import NotJustAnd from '../components/NotJustAndFaq.astro';
import Pricing from '../components/Pricing.astro';
import Logos from '../components/Logos.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { UYELIK_URL, KAYIT_URL, ROUTES } from '../config';

const menu = [
  { ad: 'Kulüpte Neler Var', href: ROUTES.kulupteNelerVar },
  { ad: 'Nasıl Çalışır', href: ROUTES.nasilCalisir },
  { ad: 'Velilere', href: ROUTES.velilere },
  { ad: 'Nasıl Üye Olunur', href: ROUTES.nasilUyeOlunur },
  { ad: 'Rehber', href: ROUTES.rehber },
];
---

<Layout>
  <div class="theme-v13 bg-[#131629] md:bg-[#131629] md:p-4">
    <div class="mx-auto max-w-[1400px] bg-white md:rounded-[8px] md:shadow-[0_30px_80px_rgba(110,124,255,.18)]">

      <div class="sticky top-0 z-50">
        <div class="flex items-center justify-center gap-2 bg-gradient-to-r from-[#2D3AAE] to-[#5060E0] px-4 py-2 text-center text-sm font-medium text-beyaz md:rounded-t-[8px]">
          <Icon name="gift" size={16} />
          Ücretsiz İki Hafta Deneyim Fırsatı
        </div>

        <header class="flex items-center justify-between gap-4 px-6 py-3 backdrop-blur-sm md:py-4 md:px-10" style="background-color: rgba(27,33,64,0.97);">
          <a href="/" class="flex items-center" aria-label="FocusClub 360"><img src="/FocusClub360_logoF_navy.png" alt="FocusClub 360" class="h-[54px] w-auto md:h-[72px]" /></a>

          <nav class="hidden items-center gap-7 lg:flex">
            {menu.map((m) => (
              <a href={m.href} class="text-sm font-medium text-[#8B96CC] transition hover:text-[#FFFFFF]">{m.ad}</a>
            ))}
          </nav>

          <div class="flex items-center gap-2 sm:gap-3">
            <a href={KAYIT_URL} class="hidden text-sm font-semibold text-[#FFFFFF] hover:opacity-70 sm:block">Üye Olun</a>
            <a
              href={UYELIK_URL}
              class="hidden rounded-buton bg-gradient-to-r from-[#6E7CFF] to-[#2D3AAE] px-5 py-2.5 text-sm font-semibold text-beyaz shadow-[0_8px_20px_rgba(110,124,255,.40)] transition hover:brightness-110 sm:inline-block"
            >2 Hafta Ücretsiz</a>
            <button id="mob-tog" aria-label="Menüyü aç" class="grid h-9 w-9 shrink-0 place-items-center rounded-[8px] border border-kenar text-[#FFFFFF] transition hover:bg-bulut focus:outline-none active:bg-[#1E2848] lg:hidden" style="-webkit-tap-highlight-color: transparent; background-color: #1B2140; -webkit-appearance: none; appearance: none;">
              <Icon name="menu" size={20} />
            </button>
          </div>
        </header>

        <!-- Marka satırı — header ile birlikte sabit kalır (yalnızca mobil/tablet) -->
        <div class="border-b border-kenar px-6 py-2 md:px-10 lg:hidden" style="background-color: rgba(27,33,64,0.97);">
          <span class="flex items-center gap-1.5 text-[11px] font-semibold leading-tight text-[#6E7CFF] md:text-[13px]">
            <Icon name="star" size={12} class="shrink-0" />
            TÜRKİYE'NİN İLK VE TEK DİJİTAL AKADEMİK ETÜT KULÜBÜ
          </span>
        </div>

        <nav id="mob-nav" class="hidden border-b border-kenar px-6 pb-5 pt-2 lg:hidden" style="background-color: #1B2140;">
          <div class="flex flex-col">
            {menu.map((m) => (
              <a href={m.href} class="mob-link rounded-[8px] px-3 py-2.5 text-sm font-medium text-[#8B96CC] transition hover:bg-bulut hover:text-[#FFFFFF]">{m.ad}</a>
            ))}
            <a href={KAYIT_URL} class="mob-link rounded-[8px] px-3 py-2.5 text-sm font-medium text-[#8B96CC] transition hover:bg-bulut hover:text-[#FFFFFF]">Üye Olun</a>
          </div>
          <a
            href={UYELIK_URL}
            class="mt-3 flex items-center justify-center gap-2 rounded-[8px] bg-gradient-to-r from-[#6E7CFF] to-[#2D3AAE] py-3 text-sm font-semibold text-beyaz"
          >
            2 Hafta Ücretsiz Dene
            <Icon name="arrow" size={16} />
          </a>
        </nav>
      </div>

      <HeroV2 />
      <BrandLine />
      <ParentProblems />
      <Approach />
      <Features />
      <HowItWorks />
      <BurdenGamification />
      <RealTeam />
      <FAQ />
      <NotJustAnd />
      <Pricing />
      <Logos />
      <Footer />
    </div>
  </div>
</Layout>

<style is:global>
  /* === THEME V13: Deep Purple + Navy === */

  /* Karanlik arka plan override */
  .theme-v13 .bg-white      { background-color: #1B2140; }
  .theme-v13 .bg-white\/95  { background-color: rgba(27, 33, 64, 0.97); }
  .theme-v13 .bg-beyaz      { background-color: #1B2140; }
  .theme-v13 .bg-beyaz\/90  { background-color: rgba(27, 33, 64, 0.90); }

  /* Input/koyu metin tokenlarini acik renge cevir */
  .theme-v13 .text-lacivert       { color: #8B96CC; }
  .theme-v13 .placeholder\:text-gri\/70::placeholder { color: rgba(100, 110, 170, 0.70); }

  /* Gradient from: #7c5cfc -> #6E7CFF */
  .theme-v13 .from-\[\#7c5cfc\] {
    --tw-gradient-from: #6E7CFF var(--tw-gradient-from-position);
    --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(110 124 255 / 0));
  }
  .theme-v13 .from-\[\#7c5cfc\]\/12 {
    --tw-gradient-from: rgb(110 124 255 / 0.12) var(--tw-gradient-from-position);
    --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(110 124 255 / 0));
  }

  /* Gradient to: #3b6ef0 -> #2D3AAE */
  .theme-v13 .to-\[\#3b6ef0\] {
    --tw-gradient-to: #2D3AAE var(--tw-gradient-to-position);
  }
  .theme-v13 .to-\[\#3b6ef0\]\/12 {
    --tw-gradient-to: rgb(45 58 174 / 0.12) var(--tw-gradient-to-position);
  }

  /* Hero mobile overlay - deep navy */
  .theme-v13 .bg-\[rgba\(28\,55\,185\,0\.75\)\] {
    background-color: rgba(19, 22, 41, 0.75);
  }

  /* Bolum arka planlari -> karanlik tonlar */
  .theme-v13 .bg-\[\#ede8ff\]  { background-color: #1B2140; }
  .theme-v13 .bg-\[\#dfe5f5\]  { background-color: #1E2545; }
  .theme-v13 .bg-\[\#e8eaf4\]  { background-color: #1C2240; }
  .theme-v13 .bg-\[\#f5f8ff\]  { background-color: #181E38; }

  /* Text renkleri */
  .theme-v13 .text-\[\#1b2a5b\]              { color: #FFFFFF; }
  .theme-v13 .text-\[\#5b6488\]              { color: #8B96CC; }
  .theme-v13 .text-\[\#6b76a0\]              { color: #6B78AA; }
  .theme-v13 .text-\[\#3b6ef0\]              { color: #6E7CFF; }
  .theme-v13 .text-\[\#7c5cfc\]              { color: #6E7CFF; }
  .theme-v13 .hover\:text-\[\#1b2a5b\]:hover { color: #FFFFFF; }

  /* Shadow renkleri */
  .theme-v13 .shadow-\[0_8px_20px_rgba\(80\,90\,240\,\.35\)\]  { box-shadow: 0 8px 20px rgba(110,124,255,.40); }
  .theme-v13 .shadow-\[0_8px_20px_rgba\(80\,90\,240\,\.30\)\]  { box-shadow: 0 8px 20px rgba(110,124,255,.35); }
  .theme-v13 .shadow-\[0_12px_30px_rgba\(40\,40\,120\,\.35\)\] { box-shadow: 0 12px 30px rgba(110,124,255,.28); }
  .theme-v13 .shadow-\[0_8px_20px_rgba\(20\,40\,120\,\.35\)\]  { box-shadow: 0 8px 20px rgba(110,124,255,.25); }

  /* Tailwind token override */
  .theme-v13 .bg-mor       { background-color: #6E7CFF; }
  .theme-v13 .bg-turkuaz   { background-color: #22D3EE; }
  .theme-v13 .bg-lacivert  { background-color: #131629; }
  .theme-v13 .bg-bulut     { background-color: #1E2848; }
  .theme-v13 .border-kenar { border-color: #2A3060; }
  .theme-v13 .text-mor     { color: #6E7CFF; }
  .theme-v13 .text-turkuaz { color: #22D3EE; }

  /* Masaustu hero overlay - deep navy */
  .theme-v13 .hero-desktop-overlay {
    background: linear-gradient(to right, rgba(19,22,41,0.92) 0%, rgba(19,22,41,0.74) 30%, rgba(19,22,41,0.34) 60%, rgba(19,22,41,0.06) 100%);
  }
</style>

<script>
  const tog = document.getElementById('mob-tog');
  const nav = document.getElementById('mob-nav');
  tog?.addEventListener('click', () => { nav?.classList.toggle('hidden'); });
  document.querySelectorAll('.mob-link').forEach((l) => {
    l.addEventListener('click', () => nav?.classList.add('hidden'));
  });
</script>
