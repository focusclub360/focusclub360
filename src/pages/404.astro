---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sayfa Bulunamadı — FocusClub 360">
  <div class="flex min-h-screen items-center justify-center bg-gradient-to-br from-[#e9e3ff] via-[#eef1ff] to-[#d9e9ff] p-6">
    <div class="text-center">
      <p class="font-baslik text-8xl font-extrabold text-[#7c5cfc]/20">404</p>
      <h1 class="mt-4 font-baslik text-2xl font-bold text-[#1b2a5b]">Sayfa bulunamadı</h1>
      <p class="mt-2 text-[#5b6488]">Aradığın sayfa henüz hazır değil.</p>
      <a
        href="/"
        class="mt-8 inline-flex items-center gap-2 rounded-[8px] bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] px-6 py-3 text-sm font-semibold text-white shadow-[0_8px_20px_rgba(80,90,240,.35)] transition hover:brightness-105"
      >
        Ana Sayfaya Dön
      </a>
    </div>
  </div>
</Layout>
