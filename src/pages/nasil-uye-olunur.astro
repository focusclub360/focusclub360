---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { UYELIK_URL, GIRIS_URL, ROUTES } from '../config';

const menu = [
  { ad: 'Kulüpte Neler Var', href: ROUTES.kulupteNelerVar },
  { ad: 'Nasıl Çalışır',     href: ROUTES.nasilCalisir    },
  { ad: 'Velilere',          href: ROUTES.velilere         },
  { ad: 'Nasıl Üye Olunur',  href: ROUTES.nasilUyeOlunur  },
  { ad: 'Rehber',            href: ROUTES.rehber           },
];

const adimlar = [
  {
    no:       '01',
    baslik:   'Ücretsiz Üye Olun',
    aciklama: 'Hızlı kayıtla hesabınızı oluşturun. Kredi kartı istemiyoruz.',
    renk:     'bg-mor',
  },
  {
    no:       '02',
    baslik:   'Deneme Başlasın',
    aciklama: 'İki hafta boyunca sistemin tamamı kullanımınıza açılır.',
    renk:     'bg-mavi',
  },
  {
    no:       '03',
    baslik:   'İlk Etüde Katılın',
    aciklama: 'Çocuğunuz gerçek öğretmen gözetiminde ilk canlı etüdüne girer.',
    renk:     'bg-turkuaz',
  },
];

const denemeMaddeleri = [
  'İki hafta boyunca sistemin tamamını deneyimleyin.',
  'Canlı etüt, gerçek koçluk, dijital içerikler ve veli raporlaması dahil.',
  'Kredi kartı gerekmez.',
  'Dilediğiniz zaman karar verirsiniz.',
];

const ozellikler = [
  { baslik: 'Canlı Etüt ve Soru Çözümü',      aciklama: 'Branş öğretmenleriyle gerçek zamanlı etüt.',        ikon: 'users',  renk: 'bg-turkuaz'  },
  { baslik: 'Gerçek Başarı Koçluğu',           aciklama: 'Kişiye özel hedef takibi ve motivasyon desteği.',   ikon: 'target', renk: 'bg-mor'      },
  { baslik: 'Yapay Zekâ Takibi ve Analizler',  aciklama: 'Her adım akıllı sistemle izlenir ve raporlanır.',  ikon: 'cpu',    renk: 'bg-lacivert' },
  { baslik: 'Online Ders İçerikleri',           aciklama: 'Tüm branşlarda video anlatım ve çözümlü sorular.', ikon: 'video',  renk: 'bg-mavi'     },
  { baslik: 'Veli Raporlama ve Bildirimler',    aciklama: 'Haftalık şeffaf ilerleme raporu veliye iletilir.', ikon: 'bell',   renk: 'bg-mercan'   },
];

const sss = [
  {
    soru:  'Ücretsiz deneme nasıl çalışır?',
    cevap: 'Üye olduktan sonra iki hafta boyunca canlı etütlere, içeriklere ve koçluğa ücretsiz erişirsiniz. Dilediğiniz zaman karar verirsiniz.',
  },
  {
    soru:  'Deneme için kredi kartı gerekiyor mu?',
    cevap: 'Hayır. Kredi kartı yalnızca üyeliğe geçmeye karar verirseniz gerekir.',
  },
  {
    soru:  'Taksit imkânı var mı?',
    cevap: 'Evet. Üyelik tüm kredi kartlarına peşin fiyatına 9 taksit yapılabilir, taksitte fiyat artmaz.',
  },
  {
    soru:  'Deneme süresince ayrılabilir miyim?',
    cevap: 'Elbette. Dilediğiniz zaman ayrılabilirsiniz, herhangi bir yükümlülük yoktur.',
  },
];
---

<Layout>
  <div class="theme-v13 bg-[#131629] md:bg-[#131629] md:p-4">
    <div class="mx-auto max-w-[1400px] bg-white md:rounded-[8px] md:shadow-[0_30px_80px_rgba(110,124,255,.18)]">

      <!-- Sticky header -->
      <div class="sticky top-0 z-50">
        <div class="flex items-center justify-center gap-2 bg-gradient-to-r from-[#2D3AAE] to-[#5060E0] px-4 py-2 text-center text-sm font-medium text-beyaz md:rounded-t-[8px]">
          <Icon name="gift" size={16} />
          Ücretsiz İki Hafta Deneyim Fırsatı
        </div>

        <header class="flex items-center justify-between gap-4 px-6 py-4 backdrop-blur-sm md:px-10" style="background-color: rgba(27,33,64,0.97);">
          <a href="/" class="flex items-center gap-2" aria-label="FocusClub 360">
            <span class="grid h-9 w-9 place-items-center rounded-kart bg-gradient-to-br from-[#6E7CFF] to-[#2D3AAE] text-beyaz">
              <Icon name="sparkles" size={20} />
            </span>
            <span class="font-baslik text-xl font-extrabold tracking-tight text-[#FFFFFF]">FocusClub
              <span class="text-[#6E7CFF]">360</span>
            </span>
          </a>

          <nav class="hidden items-center gap-7 lg:flex">
            {menu.map((m) => (
              <a
                href={m.href}
                class={`text-sm transition ${m.href === ROUTES.nasilUyeOlunur ? 'font-semibold text-[#FFFFFF]' : 'font-medium text-[#8B96CC] hover:text-[#FFFFFF]'}`}
              >
                {m.ad}
              </a>
            ))}
          </nav>

          <div class="flex items-center gap-2 sm:gap-3">
            <a href={GIRIS_URL} class="hidden text-sm font-semibold text-[#FFFFFF] hover:opacity-70 sm:block">Giriş</a>
            <a
              href={UYELIK_URL}
              class="hidden rounded-buton bg-gradient-to-r from-[#6E7CFF] to-[#2D3AAE] px-5 py-2.5 text-sm font-semibold text-beyaz shadow-[0_8px_20px_rgba(110,124,255,.40)] transition hover:brightness-110 sm:inline-block"
            >2 Hafta Ücretsiz</a>
            <button id="mob-tog" aria-label="Menüyü aç" class="grid h-9 w-9 shrink-0 place-items-center rounded-[8px] border border-kenar text-[#FFFFFF] transition hover:bg-bulut focus:outline-none active:bg-[#1E2848] lg:hidden" style="-webkit-tap-highlight-color: transparent; background-color: #1B2140; -webkit-appearance: none; appearance: none;">
              <Icon name="menu" size={20} />
            </button>
          </div>
        </header>

        <nav id="mob-nav" class="hidden border-b border-kenar px-6 pb-5 pt-2 lg:hidden" style="background-color: #1B2140;">
          <div class="flex flex-col">
            {menu.map((m) => (
              <a href={m.href} class="mob-link rounded-[8px] px-3 py-2.5 text-sm font-medium text-[#8B96CC] transition hover:bg-bulut hover:text-[#FFFFFF]">{m.ad}</a>
            ))}
          </div>
          <a
            href={UYELIK_URL}
            class="mt-3 flex items-center justify-center gap-2 rounded-[8px] bg-gradient-to-r from-[#6E7CFF] to-[#2D3AAE] py-3 text-sm font-semibold text-beyaz"
          >
            Ücretsiz Üye Ol
            <Icon name="arrow" size={16} />
          </a>
        </nav>
      </div>

      <!-- ── 1. HERO ───────────────────────────────────────────────────────────── -->
      <section class="bg-white px-6 pb-16 pt-14 md:px-10 md:pb-24 md:pt-20">
        <div class="mx-auto max-w-[1400px]">
          <div class="flex flex-col gap-12 md:flex-row md:items-center md:gap-14 lg:gap-24">

            <!-- Sol: metin -->
            <div class="flex-1">
              <span class="inline-flex items-center gap-1.5 rounded-md bg-gradient-to-r from-[#7c5cfc]/12 to-[#3b6ef0]/12 px-3 py-1 text-xs font-semibold text-[#3b6ef0]">
                <Icon name="star" size={12} class="text-[#7c5cfc]" />
                NASIL ÜYE OLUNUR
              </span>

              <h1 class="mt-5 font-baslik text-3xl font-extrabold tracking-tight text-[#1b2a5b] md:text-4xl lg:text-[2.6rem]" style="line-height: 1.18;">
                İki Hafta Ücretsiz Deneyimleyin,<br class="hidden md:block" /> Sonra Karar Verin
              </h1>

              <p class="mt-5 max-w-lg text-base leading-relaxed text-[#5b6488] md:text-lg">
                Sistemin tamamını iki hafta boyunca ücretsiz deneyimleyin. Kredi kartı gerekmez. Farkı çocuğunuzun düzeninde gördükten sonra karar verin.
              </p>

              <div class="mt-10 flex flex-wrap items-center gap-3">
                <a
                  href={UYELIK_URL}
                  class="inline-flex items-center gap-2 rounded-buton bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] py-2.5 pl-6 pr-2 text-sm font-semibold text-beyaz shadow-[0_12px_30px_rgba(40,40,120,.35)] transition hover:brightness-105"
                >
                  Ücretsiz Üye Ol
                  <span class="grid h-8 w-8 place-items-center rounded-full bg-white text-[#3b6ef0]">
                    <Icon name="arrow" size={15} />
                  </span>
                </a>
                <a
                  href={ROUTES.kulupteNelerVar}
                  class="inline-flex items-center rounded-buton border border-kenar px-5 py-2.5 text-sm font-semibold text-[#1b2a5b] transition hover:bg-bulut hover:text-[#FFFFFF]"
                >
                  Kulüpte Neler Var
                </a>
              </div>
            </div>

            <!-- Sağ: görsel placeholder (4:5) -->
            <div class="hidden shrink-0 overflow-hidden rounded-[16px] border border-kenar md:block md:w-[260px] lg:w-[320px]">
              <div class="flex aspect-[4/5] w-full flex-col items-center justify-center gap-4 bg-gradient-to-br from-[#1E2848] to-[#2A3060]">
                <span class="grid h-16 w-16 place-items-center rounded-full bg-[#6E7CFF]/20 text-[#6E7CFF]">
                  <Icon name="user" size={32} />
                </span>
                <p class="text-center text-xs text-[#5b6488]">Görsel yakında<br/>ekleniyor</p>
              </div>
            </div>

          </div>
        </div>
      </section>

      <!-- ── 2. ÜÇ ADIMDA ÜYELİK ───────────────────────────────────────────────── -->
      <section class="bg-[#f5f8ff] px-6 py-14 md:px-10 md:py-20">
        <div class="mx-auto max-w-[1400px]">

          <div class="reveal mx-auto max-w-2xl text-center">
            <h2 class="font-baslik text-3xl font-bold text-[#1b2a5b] md:text-4xl">Üç Adımda Aramıza Katılın</h2>
            <p class="mt-3 text-base text-[#5b6488]">Kayıt dakikalar içinde tamamlanır, sistem hemen açılır.</p>
          </div>

          <!-- Masaüstü: yan yana üç kart -->
          <div class="reveal mt-12 hidden items-stretch gap-0 md:flex">
            {adimlar.map((a, i) => (
              <div class="flex flex-1 items-stretch">
                <div class="flex flex-1 flex-col rounded-[8px] border border-kenar bg-white p-7 shadow-[0_4px_16px_rgba(60,80,180,.06)]">
                  <span class={`grid h-12 w-12 place-items-center rounded-full text-lg font-extrabold text-white shadow-[0_4px_12px_rgba(110,124,255,.25)] ${a.renk}`}>
                    {a.no}
                  </span>
                  <h3 class="mt-5 font-baslik text-base font-bold text-[#1b2a5b]">{a.baslik}</h3>
                  <p class="mt-2 flex-1 text-sm leading-relaxed text-[#5b6488]">{a.aciklama}</p>
                </div>
                {i < 2 && (
                  <div class="flex w-10 shrink-0 items-center justify-center text-[#5b6488]">
                    <Icon name="arrow" size={18} />
                  </div>
                )}
              </div>
            ))}
          </div>

          <!-- Mobil: dikey liste -->
          <div class="reveal mt-8 flex flex-col gap-3 md:hidden">
            {adimlar.map((a) => (
              <div class="flex items-start gap-4 rounded-[8px] border border-kenar bg-white p-5">
                <span class={`grid h-10 w-10 shrink-0 place-items-center rounded-full text-sm font-extrabold text-white ${a.renk}`}>
                  {a.no}
                </span>
                <div>
                  <h3 class="font-baslik text-sm font-bold text-[#1b2a5b]">{a.baslik}</h3>
                  <p class="mt-1 text-xs leading-relaxed text-[#5b6488]">{a.aciklama}</p>
                </div>
              </div>
            ))}
          </div>

        </div>
      </section>

      <!-- ── 3. ÜCRETSİZ DENEME DETAYLARI ─────────────────────────────────────── -->
      <section class="bg-white px-6 py-14 md:px-10 md:py-20">
        <div class="mx-auto max-w-[1400px]">
          <div class="reveal rounded-[8px] bg-lacivert px-6 py-12 md:px-10 md:py-14">

            <div class="flex flex-col gap-10 md:flex-row md:items-center md:gap-16">

              <!-- Sol: başlık + açıklama -->
              <div class="flex-1">
                <span class="inline-flex items-center gap-1.5 rounded-md bg-[#6E7CFF]/15 px-3 py-1 text-xs font-semibold text-[#8B96CC]">
                  <Icon name="gift" size={12} />
                  İki Haftalık Ücretsiz Deneyim
                </span>
                <h2 class="mt-4 font-baslik text-2xl font-bold leading-snug text-beyaz md:text-3xl">
                  Hiçbir Şey Ödemeden Başlayın
                </h2>
                <p class="mt-3 text-base leading-relaxed text-[#8B96CC]">
                  Sisteme kayıt olduğunuz anda deneyim başlar. Herhangi bir ödeme bilgisi girmenize gerek yoktur.
                </p>
              </div>

              <!-- Sağ: madde listesi -->
              <div class="flex flex-col gap-3 md:w-[340px] md:shrink-0">
                {denemeMaddeleri.map((m) => (
                  <div class="flex items-start gap-3 rounded-[8px] border border-kenar bg-beyaz px-5 py-4">
                    <span class="mt-0.5 grid h-5 w-5 shrink-0 place-items-center rounded-full bg-gradient-to-br from-[#6E7CFF] to-[#2D3AAE] text-white">
                      <Icon name="check" size={11} />
                    </span>
                    <p class="text-sm leading-relaxed text-beyaz">{m}</p>
                  </div>
                ))}
              </div>

            </div>

          </div>
        </div>
      </section>

      <!-- ── 4. TEK ÜYELİK ─────────────────────────────────────────────────────── -->
      <section class="bg-[#f5f8ff] px-6 py-14 md:px-10 md:py-20">
        <div class="mx-auto max-w-[1400px]">

          <div class="reveal mx-auto max-w-2xl text-center">
            <h2 class="font-baslik text-2xl font-bold text-[#1b2a5b] md:text-3xl">Tek Üyelik, Her Şey Dahil</h2>
            <p class="mt-2 text-sm text-[#5b6488]">İhtiyacınız olan her şey bir arada.</p>
          </div>

          <div class="reveal mt-10 rounded-[8px] border border-kenar bg-beyaz shadow-yumusak">
            <div class="grid gap-0 md:grid-cols-[1fr_1px_2fr]">

              <!-- Sol: rozet + fiyat -->
              <div class="p-8 md:p-10">
                <span class="inline-flex items-center rounded-md bg-gradient-to-r from-[#7c5cfc]/12 to-[#3b6ef0]/12 px-3 py-1 text-xs font-semibold text-[#3b6ef0]">
                  2027 LGS Hazırlık
                </span>
                <p class="mt-6 font-baslik text-4xl font-extrabold text-[#1b2a5b] sm:text-5xl">
                  54.900 <span class="text-2xl font-bold sm:text-3xl">TL</span>
                </p>
                <p class="mt-2 text-sm text-[#5b6488]">Tüm kartlara 9 taksit</p>

                <p class="mt-8 flex items-start gap-2 text-sm font-medium text-[#5b6488]">
                  <Icon name="gift" size={15} class="mt-0.5 shrink-0 text-[#7c5cfc]" />
                  Ücretsiz deneyim için kredi kartı eklemeniz gerekmez
                </p>
                <a
                  href={UYELIK_URL}
                  class="mt-4 inline-flex w-full items-center justify-center rounded-[8px] bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] px-6 py-3 text-sm font-semibold text-beyaz shadow-[0_8px_20px_rgba(80,90,240,.30)] transition hover:brightness-105"
                >
                  Ücretsiz Üye Ol
                </a>
              </div>

              <!-- Dikey ayraç -->
              <div class="hidden bg-kenar md:block"></div>

              <!-- Sağ: dahil olanlar -->
              <div class="border-t border-kenar p-8 md:border-t-0 md:p-10">
                <p class="text-xs font-semibold uppercase tracking-widest text-[#5b6488]">Üyeliğe Dahil Olanlar</p>
                <ul class="mt-6 grid gap-5 sm:grid-cols-2">
                  {ozellikler.map((o) => (
                    <li class="flex items-start gap-4">
                      <span class={`grid h-10 w-10 shrink-0 place-items-center rounded-[8px] text-beyaz ${o.renk}`}>
                        <Icon name={o.ikon} size={20} />
                      </span>
                      <div>
                        <p class="text-sm font-semibold text-[#1b2a5b]">{o.baslik}</p>
                        <p class="mt-0.5 text-xs leading-relaxed text-[#5b6488]">{o.aciklama}</p>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>

            </div>
          </div>

        </div>
      </section>

      <!-- ── 5. KAYIT DÖNEMLERİ ─────────────────────────────────────────────────── -->
      <section class="bg-white px-6 py-14 md:px-10 md:py-20">
        <div class="mx-auto max-w-[1400px]">
          <div class="reveal mx-auto max-w-2xl text-center">
            <h2 class="font-baslik text-3xl font-bold text-[#1b2a5b] md:text-4xl">Kayıt Dönemleri</h2>
            <p class="mt-5 text-base leading-relaxed text-[#5b6488]">
              Akademik yıl kademeli kayıt dönemlerine ayrılır. Dilediğiniz dönemde aramıza katılabilir, çocuğunuzun düzenini erkenden kurmaya başlayabilirsiniz.
            </p>
            <p class="mt-6 text-sm text-[#5b6488]/60">
              Güncel dönem bilgisini üyelik sırasında görürsünüz.
            </p>
          </div>
        </div>
      </section>

      <!-- ── 6. KISA SSS + CTA ──────────────────────────────────────────────────── -->
      <section class="bg-[#f5f8ff] px-6 pb-14 pt-14 md:px-10 md:pb-20 md:pt-20">
        <div class="mx-auto max-w-[1400px]">

          <div class="reveal mx-auto max-w-2xl text-center">
            <h2 class="font-baslik text-3xl font-bold text-[#1b2a5b] md:text-4xl">Aklınıza Takılanlar</h2>
          </div>

          <div class="reveal mx-auto mt-10 max-w-2xl divide-y divide-kenar overflow-hidden rounded-[8px] border border-kenar bg-beyaz">
            {sss.map((s) => (
              <details class="faq-item group px-6 py-5">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 select-none">
                  <span class="font-baslik text-sm font-semibold text-[#1b2a5b] md:text-base">{s.soru}</span>
                  <span class="faq-chevron shrink-0 text-[#5b6488] transition-transform duration-200">
                    <Icon name="chevron" size={18} />
                  </span>
                </summary>
                <p class="mt-3 text-sm leading-relaxed text-[#5b6488]">{s.cevap}</p>
              </details>
            ))}
          </div>

          <!-- CTA bandi -->
          <div class="reveal mt-14 overflow-hidden rounded-[8px] bg-gradient-to-br from-[#2D3AAE] via-[#3D4EC8] to-[#5060E0] px-6 py-12 text-center md:px-14 md:py-16">

            <h2 class="font-baslik text-2xl font-bold text-white md:text-3xl">
              Hazır Olduğunuzda Bekliyoruz
            </h2>
            <p class="mx-auto mt-3 max-w-md text-sm leading-relaxed text-white/75 md:text-base">
              İlk iki hafta ücretsiz. Kredi kartı gerekmez. Dilediğiniz zaman ayrılabilirsiniz.
            </p>

            <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
              <a
                href={UYELIK_URL}
                class="inline-flex items-center gap-2 rounded-buton py-2.5 pl-6 pr-2 text-sm font-semibold shadow-[0_8px_24px_rgba(0,0,0,.20)] transition hover:brightness-95"
                style="background-color: #FFFFFF; color: #2D3AAE;"
              >
                Ücretsiz Üye Ol
                <span class="grid h-8 w-8 place-items-center rounded-full text-white" style="background-color: #3b6ef0;">
                  <Icon name="arrow" size={15} />
                </span>
              </a>
              <a
                href="/bize-ulasin"
                class="inline-flex items-center rounded-buton border border-white/40 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-white/10"
              >
                Bize Ulaşın
              </a>
            </div>

          </div>

        </div>
      </section>

      <Footer />
    </div>
  </div>
</Layout>

<style is:global>
  /* === THEME V13: Deep Purple + Navy === */
  .theme-v13 .bg-white      { background-color: #1B2140; }
  .theme-v13 .bg-white\/95  { background-color: rgba(27, 33, 64, 0.97); }
  .theme-v13 .bg-beyaz      { background-color: #1B2140; }
  .theme-v13 .bg-beyaz\/90  { background-color: rgba(27, 33, 64, 0.90); }

  .theme-v13 .text-lacivert       { color: #8B96CC; }
  .theme-v13 .placeholder\:text-gri\/70::placeholder { color: rgba(100, 110, 170, 0.70); }

  .theme-v13 .from-\[\#7c5cfc\] {
    --tw-gradient-from: #6E7CFF var(--tw-gradient-from-position);
    --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(110 124 255 / 0));
  }
  .theme-v13 .from-\[\#7c5cfc\]\/12 {
    --tw-gradient-from: rgb(110 124 255 / 0.12) var(--tw-gradient-from-position);
    --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(110 124 255 / 0));
  }
  .theme-v13 .to-\[\#3b6ef0\] {
    --tw-gradient-to: #2D3AAE var(--tw-gradient-to-position);
  }
  .theme-v13 .to-\[\#3b6ef0\]\/12 {
    --tw-gradient-to: rgb(45 58 174 / 0.12) var(--tw-gradient-to-position);
  }

  .theme-v13 .bg-\[\#ede8ff\]  { background-color: #1B2140; }
  .theme-v13 .bg-\[\#dfe5f5\]  { background-color: #1E2545; }
  .theme-v13 .bg-\[\#e8eaf4\]  { background-color: #1C2240; }
  .theme-v13 .bg-\[\#f5f8ff\]  { background-color: #181E38; }

  .theme-v13 .text-\[\#1b2a5b\]              { color: #FFFFFF; }
  .theme-v13 .text-\[\#5b6488\]              { color: #8B96CC; }
  .theme-v13 .text-\[\#6b76a0\]              { color: #6B78AA; }
  .theme-v13 .text-\[\#3b6ef0\]              { color: #6E7CFF; }
  .theme-v13 .text-\[\#7c5cfc\]              { color: #6E7CFF; }
