<script>
  const tog = document.getElementById('mob-tog');
  const nav = document.getElementById('mob-nav');
  tog?.addEventListener('click', () => { nav?.classList.toggle('hidden'); });
  document.querySelectorAll('.mob-link').forEach((l) => {
    l.addEventListener('click', () => nav?.classList.add('hidden'));
  });

  // FAQ chevron rotation
  document.querySelectorAll('.faq-item').forEach((el) => {
    el.addEventListener('toggle', () => {
      const chevron = el.querySelector('.faq-chevron') as HTMLElement | null;
      if (!chevron) return;
      if ((el as HTMLDetailsElement).open) {
        chevron.style.transform = 'rotate(180deg)';
      } else {
        chevron.style.transform = '';
      }
    });
  });

  // Scroll fade-in
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) { (e.target as HTMLElement).classList.add('gorunur'); } }),
    { threshold: 0.08 }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .reveal.gorunur {
    opacity: 1;
    transform: translateY(0);
  }
  details > summary::-webkit-details-marker { display: none; }
  details > summary { list-style: none; }
</style>
