---
import Layout from '../layouts/Layout.astro';
import HeroV2 from '../components/HeroV2.astro';
import BrandLine from '../components/BrandLine.astro';
import Approach from '../components/Approach.astro';
import Features from '../components/Features.astro';
import HowItWorks from '../components/HowItWorks.astro';
import BurdenGamification from '../components/BurdenGamification.astro';
import ParentProblems from '../components/ParentProblems.astro';
import RealTeam from '../components/RealTeam.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import NotJustAnd from '../components/NotJustAndFaq.astro';
import Pricing from '../components/Pricing.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { UYELIK_URL, GIRIS_URL, ROUTES } from '../config';

const menu = [
  { ad: 'Kulüpte Neler Var', href: ROUTES.kulupteNelerVar },
  { ad: 'Nasıl Çalışır', href: ROUTES.nasilCalisir },
  { ad: 'Velilere', href: ROUTES.velilere },
  { ad: 'Nasıl Üye Olunur', href: ROUTES.nasilUyeOlunur },
  { ad: 'Rehber', href: ROUTES.rehber },
];
---

<Layout>
  <div class="theme-v14 bg-[#F8F9FA] md:bg-[#F8F9FA] md:p-4">
    <div class="mx-auto max-w-[1400px] bg-white md:rounded-[8px] md:shadow-[0_30px_80px_rgba(26,35,126,.10)]">

      <div class="sticky top-0 z-50">
        <div class="flex items-center justify-center gap-2 bg-[#1A237E] px-4 py-2 text-center text-sm font-medium text-beyaz md:rounded-t-[8px]">
          <Icon name="gift" size={16} />
          Sınırlı süre için ücretsiz 2 hafta deneme fırsatı
        </div>

        <header class="flex items-center justify-between gap-4 bg-white/95 px-6 py-4 backdrop-blur-sm md:px-10">
          <a href="/" class="flex items-center gap-2" aria-label="FocusClub 360">
            <span class="grid h-9 w-9 place-items-center rounded-kart bg-gradient-to-br from-[#1A237E] to-[#283593] text-beyaz">
              <Icon name="sparkles" size={20} />
            </span>
            <span class="font-baslik text-xl font-extrabold tracking-tight text-[#1F2937]">FocusClub
              <span class="text-[#FFC107]">360</span>
            </span>
          </a>

          <nav class="hidden items-center gap-7 lg:flex">
            {menu.map((m) => (
              <a href={m.href} class="text-sm font-medium text-[#4B5563] transition hover:text-[#1F2937]">{m.ad}</a>
            ))}
          </nav>

          <div class="flex items-center gap-2 sm:gap-3">
            <a href={GIRIS_URL} class="hidden text-sm font-semibold text-[#1F2937] hover:opacity-70 sm:block">Giriş</a>
            <a
              href={UYELIK_URL}
              class="hidden rounded-buton bg-[#FFC107] px-5 py-2.5 text-sm font-semibold text-[#1F2937] shadow-[0_8px_20px_rgba(255,193,7,.40)] transition hover:brightness-105 sm:inline-block"
            >2 Hafta Ücretsiz</a>
            <button id="mob-tog" aria-label="Menüyü aç" class="grid h-9 w-9 shrink-0 place-items-center rounded-[8px] border border-kenar text-[#1F2937] transition hover:bg-bulut lg:hidden">
              <Icon name="menu" size={20} />
            </button>
          </div>
        </header>

        <nav id="mob-nav" class="hidden border-b border-kenar bg-white px-6 pb-5 pt-2 lg:hidden">
          <div class="flex flex-col">
            {menu.map((m) => (
              <a href={m.href} class="mob-link rounded-[8px] px-3 py-2.5 text-sm font-medium text-[#4B5563] transition hover:bg-bulut hover:text-[#1F2937]">{m.ad}</a>
            ))}
          </div>
          <a
            href={UYELIK_URL}
            class="mt-3 flex items-center justify-center gap-2 rounded-[8px] bg-[#FFC107] py-3 text-sm font-semibold text-[#1F2937]"
          >
            2 Hafta Ücretsiz Dene
            <Icon name="arrow" size={16} />
          </a>
        </nav>
      </div>

      <HeroV2 />
      <BrandLine />
      <ParentProblems />
      <Approach />
      <Features />
      <HowItWorks />
      <BurdenGamification />
      <RealTeam />
      <FAQ />
      <Testimonials />
      <NotJustAnd />
      <Pricing />
      <Footer />
    </div>
  </div>
</Layout>

<style is:global>
  /* === THEME V14: Derin Lacivert + Hardal + Zumrut === */

  /* Gradient from: #7c5cfc -> #1A237E */
  .theme-v14 .from-\[\#7c5cfc\] {
    --tw-gradient-from: #1A237E var(--tw-gradient-from-position);
    --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(26 35 126 / 0));
  }
  .theme-v14 .from-\[\#7c5cfc\]\/12 {
    --tw-gradient-from: rgb(26 35 126 / 0.12) var(--tw-gradient-from-position);
    --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(26 35 126 / 0));
  }

  /* Gradient to: #3b6ef0 -> #283593 */
  .theme-v14 .to-\[\#3b6ef0\] {
    --tw-gradient-to: #283593 var(--tw-gradient-to-position);
  }
  .theme-v14 .to-\[\#3b6ef0\]\/12 {
    --tw-gradient-to: rgb(40 53 147 / 0.12) var(--tw-gradient-to-position);
  }

  /* CTA butonlarini hardal rengine donustur */
  .theme-v14 .bg-gradient-to-r.from-\[\#7c5cfc\] {
    background-image: none;
    background-color: #FFC107;
  }

  /* Hero mobile overlay - derin lacivert */
  .theme-v14 .bg-\[rgba\(28\,55\,185\,0\.75\)\] {
    background-color: rgba(26, 35, 126, 0.82);
  }

  /* Bolum arka planlari -> kar beyazi/acik tonu */
  .theme-v14 .bg-\[\#ede8ff\]  { background-color: #EEF0FF; }
  .theme-v14 .bg-\[\#dfe5f5\]  { background-color: #E8EBFF; }
  .theme-v14 .bg-\[\#e8eaf4\]  { background-color: #ECEFFE; }
  .theme-v14 .bg-\[\#f5f8ff\]  { background-color: #F4F6FE; }

  /* Text renkleri */
  .theme-v14 .text-\[\#1b2a5b\]              { color: #1F2937; }
  .theme-v14 .text-\[\#5b6488\]              { color: #4B5563; }
  .theme-v14 .text-\[\#6b76a0\]              { color: #6B7280; }
  .theme-v14 .text-\[\#3b6ef0\]              { color: #1A237E; }
  .theme-v14 .text-\[\#7c5cfc\]              { color: #1A237E; }
  .theme-v14 .hover\:text-\[\#1b2a5b\]:hover { color: #1F2937; }

  /* Shadow renkleri */
  .theme-v14 .shadow-\[0_8px_20px_rgba\(80\,90\,240\,\.35\)\]  { box-shadow: 0 8px 20px rgba(26,35,126,.25); }
  .theme-v14 .shadow-\[0_8px_20px_rgba\(80\,90\,240\,\.30\)\]  { box-shadow: 0 8px 20px rgba(26,35,126,.22); }
  .theme-v14 .shadow-\[0_12px_30px_rgba\(40\,40\,120\,\.35\)\] { box-shadow: 0 12px 30px rgba(26,35,126,.28); }
  .theme-v14 .shadow-\[0_8px_20px_rgba\(20\,40\,120\,\.35\)\]  { box-shadow: 0 8px 20px rgba(26,35,126,.20); }

  /* Tailwind token override */
  .theme-v14 .bg-mor       { background-color: #1A237E; }
  .theme-v14 .bg-turkuaz   { background-color: #10B981; }
  .theme-v14 .bg-lacivert  { background-color: #1A237E; }
  .theme-v14 .bg-bulut     { background-color: #F8F9FA; }
  .theme-v14 .border-kenar { border-color: #E5E7EB; }
  .theme-v14 .text-mor     { color: #1A237E; }
  .theme-v14 .text-turkuaz { color: #10B981; }

  /* Zumrut yesil: tikler ve rozet basarilari */
  .theme-v14 .text-\[\#7c5cfc\].text-xs { color: #10B981; }

  /* Masaustu hero overlay - derin lacivert */
  .theme-v14 .hero-desktop-overlay {
    background: linear-gradient(to right, rgba(26,35,126,0.88) 0%, rgba(26,35,126,0.66) 30%, rgba(26,35,126,0.24) 60%, rgba(26,35,126,0.06) 100%);
  }
</style>

<script>
  const tog = document.getElementById('mob-tog');
  const nav = document.getElementById('mob-nav');
  tog?.addEventListener('click', () => { nav?.classList.toggle('hidden'); });
  document.querySelectorAll('.mob-link').forEach((l) => {
    l.addEventListener('click', () => nav?.classList.add('hidden'));
  });
</script>
