---
import Layout from '../layouts/Layout.astro';
import HeroV2 from '../components/HeroV2.astro';
import BrandLine from '../components/BrandLine.astro';
import Approach from '../components/Approach.astro';
import Features from '../components/Features.astro';
import HowItWorks from '../components/HowItWorks.astro';
import BurdenGamification from '../components/BurdenGamification.astro';
import ParentProblems from '../components/ParentProblems.astro';
import RealTeam from '../components/RealTeam.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import NotJustAnd from '../components/NotJustAndFaq.astro';
import Pricing from '../components/Pricing.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { UYELIK_URL, GIRIS_URL, ROUTES } from '../config';

const menu = [
  { ad: 'Kulüpte Neler Var', href: ROUTES.kulupteNelerVar },
  { ad: 'Nasıl Çalışır', href: ROUTES.nasilCalisir },
  { ad: 'Velilere', href: ROUTES.velilere },
  { ad: 'Nasıl Üye Olunur', href: ROUTES.nasilUyeOlunur },
  { ad: 'Rehber', href: ROUTES.rehber },
];
---

<Layout>
  <div class="theme-v8 md:bg-gradient-to-br md:from-[#F1F7E8] md:via-[#F4F6F3] md:to-[#E8F6EC] md:p-4">
    <div class="mx-auto max-w-[1400px] bg-white md:rounded-[8px] md:shadow-[0_30px_80px_rgba(101,163,13,.10)]">

      <div class="sticky top-0 z-50">
        <div class="flex items-center justify-center gap-2 bg-gradient-to-r from-[#65A30D] to-[#16A34A] px-4 py-2 text-center text-sm font-medium text-beyaz md:rounded-t-[8px]">
          <Icon name="gift" size={16} />
          Sınırlı süre için ücretsiz 2 hafta deneme fırsatı
        </div>

        <header class="flex items-center justify-between gap-4 bg-white/95 px-6 py-4 backdrop-blur-sm md:px-10">
          <a href="/" class="flex items-center gap-2" aria-label="FocusClub 360">
            <span class="grid h-9 w-9 place-items-center rounded-kart bg-gradient-to-br from-[#65A30D] to-[#16A34A] text-beyaz">
              <Icon name="sparkles" size={20} />
            </span>
            <span class="font-baslik text-xl font-extrabold tracking-tight text-[#161B22]">FocusClub
              <span class="text-[#84CC16]">360</span>
            </span>
          </a>

          <nav class="hidden items-center gap-7 lg:flex">
            {menu.map((m) => (
              <a href={m.href} class="text-sm font-medium text-[#5b6470] transition hover:text-[#161B22]">{m.ad}</a>
            ))}
          </nav>

          <div class="flex items-center gap-2 sm:gap-3">
            <a href={GIRIS_URL} class="hidden text-sm font-semibold text-[#161B22] hover:opacity-70 sm:block">Giriş</a>
            <a
              href={UYELIK_URL}
              class="hidden rounded-buton bg-gradient-to-r from-[#65A30D] to-[#16A34A] px-5 py-2.5 text-sm font-semibold text-beyaz shadow-[0_8px_20px_rgba(101,163,13,.35)] transition hover:brightness-105 sm:inline-block"
            >2 Hafta Ücretsiz</a>
            <button id="mob-tog" aria-label="Menüyü aç" class="grid h-9 w-9 shrink-0 place-items-center rounded-[8px] border border-kenar text-[#161B22] transition hover:bg-bulut lg:hidden">
              <Icon name="menu" size={20} />
            </button>
          </div>
        </header>

        <nav id="mob-nav" class="hidden border-b border-kenar bg-white px-6 pb-5 pt-2 lg:hidden">
          <div class="flex flex-col">
            {menu.map((m) => (
              <a href={m.href} class="mob-link rounded-[8px] px-3 py-2.5 text-sm font-medium text-[#5b6470] transition hover:bg-bulut hover:text-[#161B22]">{m.ad}</a>
            ))}
          </div>
          <a
            href={UYELIK_URL}
            class="mt-3 flex items-center justify-center gap-2 rounded-[8px] bg-gradient-to-r from-[#65A30D] to-[#16A34A] py-3 text-sm font-semibold text-beyaz"
          >
            2 Hafta Ücretsiz Dene
            <Icon name="arrow" size={16} />
          </a>
        </nav>
      </div>

      <HeroV2 />
      <BrandLine />
      <ParentProblems />
      <Approach />
      <Features />
      <HowItWorks />
      <BurdenGamification />
      <RealTeam />
      <FAQ />
      <Testimonials />
      <NotJustAnd />
      <Pricing />
      <Footer />
    </div>
  </div>
</Layout>

<style is:global>
  /* === THEME V8: Antrasit + Lime === */

  /* Gradient from: #7c5cfc -> #65A30D */
  .theme-v8 .from-\[\#7c5cfc\] {
    --tw-gradient-from: #65A30D var(--tw-gradient-from-position);
    --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(101 163 13 / 0));
  }
  .theme-v8 .from-\[\#7c5cfc\]\/12 {
    --tw-gradient-from: rgb(101 163 13 / 0.12) var(--tw-gradient-from-position);
    --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(101 163 13 / 0));
  }

  /* Gradient to: #3b6ef0 -> #16A34A */
  .theme-v8 .to-\[\#3b6ef0\] {
    --tw-gradient-to: #16A34A var(--tw-gradient-to-position);
  }
  .theme-v8 .to-\[\#3b6ef0\]\/12 {
    --tw-gradient-to: rgb(22 163 74 / 0.12) var(--tw-gradient-to-position);
  }

  /* Hero mobile overlay */
  .theme-v8 .bg-\[rgba\(28\,55\,185\,0\.75\)\] {
    background-color: rgba(35, 42, 54, 0.82);
  }

  /* Acik mor arka planlar -> acik lime/yesil tonu */
  .theme-v8 .bg-\[\#ede8ff\]  { background-color: #edf5e1; }
  .theme-v8 .bg-\[\#dfe5f5\]  { background-color: #e5f0d8; }
  .theme-v8 .bg-\[\#e8eaf4\]  { background-color: #eaf3e0; }
  .theme-v8 .bg-\[\#f5f8ff\]  { background-color: #f4f8ee; }

  /* Text renkleri */
  .theme-v8 .text-\[\#1b2a5b\] { color: #161B22; }
  .theme-v8 .text-\[\#5b6488\] { color: #5b6470; }
  .theme-v8 .text-\[\#6b76a0\] { color: #828b96; }
  .theme-v8 .text-\[\#3b6ef0\] { color: #16A34A; }
  .theme-v8 .text-\[\#7c5cfc\] { color: #65A30D; }
  .theme-v8 .hover\:text-\[\#1b2a5b\]:hover { color: #161B22; }

  /* Shadow renkleri */
  .theme-v8 .shadow-\[0_8px_20px_rgba\(80\,90\,240\,\.35\)\]  { box-shadow: 0 8px 20px rgba(101,163,13,.35); }
  .theme-v8 .shadow-\[0_8px_20px_rgba\(80\,90\,240\,\.30\)\]  { box-shadow: 0 8px 20px rgba(101,163,13,.30); }
  .theme-v8 .shadow-\[0_12px_30px_rgba\(40\,40\,120\,\.35\)\] { box-shadow: 0 12px 30px rgba(101,163,13,.30); }
  .theme-v8 .shadow-\[0_8px_20px_rgba\(20\,40\,120\,\.35\)\]  { box-shadow: 0 8px 20px rgba(101,163,13,.25); }

  /* Tailwind token override */
  .theme-v8 .bg-mor      { background-color: #65A30D; }
  .theme-v8 .bg-turkuaz  { background-color: #06B6D4; }
  .theme-v8 .bg-lacivert { background-color: #161B22; }
  .theme-v8 .bg-bulut    { background-color: #F4F6F3; }
  .theme-v8 .border-kenar { border-color: #E6EAE5; }
  .theme-v8 .text-mor    { color: #65A30D; }
  .theme-v8 .text-turkuaz { color: #06B6D4; }

  /* Masaustu hero overlay */
  .theme-v8 .hero-desktop-overlay {
    background: linear-gradient(to right, rgba(35,42,54,0.88) 0%, rgba(35,42,54,0.68) 30%, rgba(35,42,54,0.28) 60%, rgba(35,42,54,0.06) 100%);
  }
</style>

<script>
  const tog = document.getElementById('mob-tog');
  const nav = document.getElementById('mob-nav');
  tog?.addEventListener('click', () => { nav?.classList.toggle('hidden'); });
  document.querySelectorAll('.mob-link').forEach((l) => {
    l.addEventListener('click', () => nav?.classList.add('hidden'));
  });
</script>
