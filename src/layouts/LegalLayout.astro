---
import Layout from './Layout.astro';
import Footer from '../components/Footer.astro';
import SiteHeader from '../components/SiteHeader.astro';

interface Props {
  title: string;
  description?: string;
  baslik: string;
  guncelleme?: string;
}

const { title, description, baslik, guncelleme } = Astro.props;
---

<Layout title={title} description={description}>
  <div class="theme-v13 bg-[#131629] md:bg-[#131629] md:p-4">
    <div class="mx-auto max-w-[1400px] bg-white md:rounded-[8px] md:shadow-[0_30px_80px_rgba(110,124,255,.18)]">

      <SiteHeader />

      <!-- İçerik -->
      <section class="bg-white px-6 py-12 md:px-10 md:py-16">
        <div class="mx-auto max-w-[760px]">
          <h1 class="font-baslik text-3xl font-extrabold tracking-tight text-[#FFFFFF] md:text-4xl">{baslik}</h1>
          {guncelleme && (
            <p class="mt-3 text-sm text-[#5B6E9E]">Son güncelleme: {guncelleme}</p>
          )}
          <div class="legal-prose mt-8">
            <slot />
          </div>
        </div>
      </section>

      <Footer />
    </div>
  </div>
</Layout>

<style is:global>
  /* THEME V13 koyu arka plan override (diğer iç sayfalarla aynı) */
  .theme-v13 .bg-white { background-color: #1B2140; }

  .theme-v13 .legal-prose h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: #FFFFFF;
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
  }
  .theme-v13 .legal-prose h3 {
    font-family: 'Poppins', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #FFFFFF;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .theme-v13 .legal-prose p {
    color: #8B96CC;
    line-height: 1.8;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }
  .theme-v13 .legal-prose ul {
    list-style: disc;
    padding-left: 1.4rem;
    margin-bottom: 1rem;
  }
  .theme-v13 .legal-prose li {
    color: #8B96CC;
    line-height: 1.75;
    margin-bottom: 0.4rem;
    font-size: 0.95rem;
  }
  .theme-v13 .legal-prose strong { color: #C7CDF0; font-weight: 600; }
  .theme-v13 .legal-prose a { color: #8B9BFF; text-decoration: underline; text-underline-offset: 2px; }
  .theme-v13 .legal-prose a:hover { color: #FFFFFF; }
  .theme-v13 .legal-prose hr { border: 0; border-top: 1px solid #2A2F52; margin: 2rem 0; }
</style>
