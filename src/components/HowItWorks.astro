---
const adimlar = [
  { no: '01', baslik: 'Üye Ol',                                             ikon: 'user',   renk: 'bg-turkuaz'  },
  { no: '02', baslik: 'Programa Katıl',                                     ikon: 'list',   renk: 'bg-amber'    },
  { no: '03', baslik: 'Akıllı Öğretim Ekosistemine Erişim Kazan',           ikon: 'video',  renk: 'bg-mor'      },
  { no: '04', baslik: 'Canlı Etüt ve Soru-Cevap Derslerini Başlat',        ikon: 'users',  renk: 'bg-mavi'     },
  { no: '05', baslik: 'Eğitim Koçunla Tanış ve Destek Almaya Başla',       ikon: 'target', renk: 'bg-mercan'   },
  { no: '06', baslik: 'Gelişimini Anlık Olarak İzle',                      ikon: 'eye',    renk: 'bg-turkuaz'  },
  { no: '07', baslik: 'Konu Kazanımlarını ve Program Başarını Takip Et',   ikon: 'cpu',    renk: 'bg-amber'    },
  { no: '08', baslik: 'Kariyer ve Okul tercihlerin için danışmanlık al.',  ikon: 'trophy', renk: 'bg-mor'      },
];
---

<section id="nasil-calisir" class="bg-white px-6 pb-6 pt-0 md:px-10 md:pb-8">
  <div class="mx-auto max-w-[1400px]">
    <div class="reveal rounded-[8px] bg-lacivert px-6 py-12 md:px-10 md:py-14">

      <!-- Başlık -->
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="font-baslik text-2xl font-bold text-beyaz md:text-3xl">
          Canlı Etüt Sistemi Nasıl Çalışır?
        </h2>
      </div>

      <!-- Adımlar -->
      <div class="mt-10 grid gap-px sm:grid-cols-2">
        {adimlar.map((a, i) => (
          <div class={`flex items-center gap-3 p-4 sm:gap-4 sm:p-6 ${i < 6 ? 'sm:border-b sm:border-beyaz/10' : ''} ${i % 2 === 0 ? 'sm:border-r sm:border-beyaz/10' : ''}`}>
            <!-- Numaralı daire -->
            <span class={`grid h-10 w-10 shrink-0 place-items-center rounded-full font-baslik text-sm font-extrabold text-beyaz sm:h-12 sm:w-12 sm:text-base ${a.renk}`}>
              {a.no}
            </span>
            <!-- Metin -->
            <div class="min-w-0">
              <p class="font-baslik text-base font-semibold text-beyaz">{a.baslik}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
