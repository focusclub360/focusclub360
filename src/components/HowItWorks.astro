---
import Icon from './Icon.astro';

const adimlar = [
  { no: '01', baslik: 'Üye Ol',                        aciklama: 'Hızlı üyelik ile hesabını oluştur.',                                         ikon: 'user',   renk: 'bg-turkuaz'  },
  { no: '02', baslik: 'Programa Katıl',                 aciklama: 'Etüt kulübünde yerini al.',                                                   ikon: 'list',   renk: 'bg-amber'    },
  { no: '03', baslik: 'Online Dijital İçerikler',       aciklama: 'Tüm branşlarda video ve içeriklere ulaş.',                                    ikon: 'video',  renk: 'bg-mor'      },
  { no: '04', baslik: 'Canlı Etüde Başla',              aciklama: 'Branş öğretmenleriyle canlı etüt ve soru çözümlerine katıl.',                 ikon: 'users',  renk: 'bg-mavi'     },
  { no: '05', baslik: 'Koçluk Programına Katıl',        aciklama: 'Gerçek rehber öğretmenlerden kişiye özel destek al.',                         ikon: 'target', renk: 'bg-mercan'   },
  { no: '06', baslik: 'Şeffaf Raporlama ve İlerleyiş',  aciklama: 'Her anın yapay zekâ ile takip edilip düzenli bildirilsin.',                   ikon: 'cpu',    renk: 'bg-turkuaz'  },
];
---

<section id="nasil-calisir" class="bg-white px-6 pb-6 pt-0 md:px-10 md:pb-8">
  <div class="mx-auto max-w-[1400px]">
    <div class="reveal rounded-[8px] bg-lacivert px-6 py-12 md:px-10 md:py-14">

      <!-- Başlık -->
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="font-baslik text-2xl font-bold text-beyaz md:text-3xl">
          Canlı Etüt Sistemi Nasıl Çalışır?
        </h2>
      </div>

      <!-- Adımlar -->
      <div class="mt-10 grid gap-px sm:grid-cols-2">
        {adimlar.map((a, i) => (
          <div class={`flex items-start gap-4 p-6 ${i < 4 ? 'sm:border-b sm:border-beyaz/10' : ''} ${i % 2 === 0 ? 'sm:border-r sm:border-beyaz/10' : ''}`}>
            <!-- Numaralı daire -->
            <span class={`grid h-12 w-12 shrink-0 place-items-center rounded-full font-baslik text-base font-extrabold text-beyaz ${a.renk}`}>
              {a.no}
            </span>
            <!-- İkon -->
            <span class="mt-0.5 grid h-11 w-11 shrink-0 place-items-center rounded-[8px] bg-beyaz/10 text-beyaz/70">
              <Icon name={a.ikon} size={22} />
            </span>
            <!-- Metin -->
            <div class="min-w-0">
              <p class="font-baslik text-base font-semibold text-beyaz">{a.baslik}</p>
              <p class="mt-1 text-sm leading-relaxed text-beyaz/60">{a.aciklama}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
