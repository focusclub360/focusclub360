---
import Icon from './Icon.astro';
import { UYELIK_URL } from '../config';
---

<section class="konteyner py-16 md:py-24">
  <div class="reveal overflow-hidden rounded-bant bg-gradient-to-r from-turkuaz to-amber px-6 py-14 text-center shadow-yumusak md:px-12 md:py-16">
    <h2 class="mx-auto max-w-3xl font-baslik text-3xl font-extrabold leading-tight text-beyaz md:text-4xl">
      Çocuğunuzu 2 hafta boyunca ücretsiz, tam erişimle deneyin
    </h2>
    <p class="mt-4 flex items-center justify-center gap-2 text-beyaz/90">
      <Icon name="shield" size={18} />
      Ücretsiz denemede kredi kartı gerekmez.
    </p>
    <a
      href={UYELIK_URL}
      class="mt-8 inline-flex items-center justify-center gap-2 rounded-buton bg-beyaz px-7 py-3.5 font-semibold text-lacivert shadow-kucuk transition hover:-translate-y-0.5 hover:shadow-yumusak"
    >
      Ücretsiz Üye Olun
      <Icon name="arrow" size={18} />
    </a>
  </div>
</section>
