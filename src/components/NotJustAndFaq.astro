---
import Icon from './Icon.astro';

const satirlar = [
  { sol: 'Sadece video izleme değil',    sag: 'Canlı etkileşim, anında geri bildirim'              },
  { sol: 'Sadece soru çözümü değil',     sag: 'Koçluk desteğiyle sürdürülebilir çalışma'           },
  { sol: 'Sadece deneme çözmek değil',   sag: 'Yapay zekâ destekli takip ve analiz'                },
  { sol: 'Sadece düzen değil',           sag: 'Ölçülebilir akademik gelişim ve LGS başarısı'       },
  { sol: 'Sadece bilgi değil',           sag: 'Alışkanlık kazandıran bütünsel gelişim'              },
];
---

<section class="bg-white px-6 pb-6 pt-0 md:px-10 md:pb-8">
  <div class="mx-auto max-w-[1400px]">
    <div class="reveal rounded-[8px] bg-bulut px-6 py-10 md:px-10 md:py-12">

      <h2 class="font-baslik text-xl font-bold text-[#1b2a5b] md:text-2xl">
        Sadece&nbsp;<span class="bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] bg-clip-text text-transparent">online bir eğitim</span>&nbsp;değil
      </h2>

      <div class="mt-6 divide-y divide-kenar">
        {satirlar.map((r) => (
          <div class="flex flex-col gap-2 py-4 lg:grid lg:grid-cols-[1fr_auto_1fr] lg:items-center lg:gap-8">
            <p class="text-sm font-medium text-[#5b6488] md:text-base">{r.sol}</p>
            <span class="grid h-8 w-8 shrink-0 place-items-center self-center rounded-[8px] bg-gradient-to-br from-[#7c5cfc] to-[#3b6ef0] text-beyaz rotate-90 lg:rotate-0">
              <Icon name="arrow" size={15} />
            </span>
            <p class="text-sm font-semibold text-[#1b2a5b] md:text-base">{r.sag}</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
