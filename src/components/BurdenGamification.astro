---
import { Image } from 'astro:assets';
import veliFoto from '../assets/sss-bolum.jpg';
---

<section class="bg-white px-6 pb-6 pt-0 md:px-10 md:pb-8">
  <div class="mx-auto max-w-[1400px]">
    <div class="reveal rounded-[8px] bg-bulut px-6 py-12 md:px-10 md:py-14">

      <div class="grid items-center gap-10 lg:grid-cols-2">

        <!-- Sol: metin -->
        <div>
          <h2 class="font-baslik text-2xl font-bold leading-tight text-[#1b2a5b] md:text-3xl">
            Bu Huzur Sizin Hakkınız!
          </h2>
          <p class="mt-2 font-baslik text-lg font-semibold leading-tight text-[#1b2a5b] md:text-xl">
            Akşamları evde sürekli "Ders çalış" demekten yorulduğunuz o yıpratıcı günleri geride bırakın.
          </p>
          <p class="mt-4 text-base leading-relaxed text-[#5b6488]">
            Canlı etütler ve interaktif soru-çözüm seanslarıyla, ders çalıştırma yükünü ebeveynlerin omuzlarından alıp FocusClub 360'a taşıyoruz. Çocuğunuz uzman rehberliğinde kendi sorumluluğunu alarak düzenli çalışırken; size sadece veli olmanın, evdeki huzurun ve mutlu aile anlarının keyfini sürmek kalıyor.
          </p>
        </div>

        <!-- Sağ: aile görseli -->
        <div class="overflow-hidden rounded-[8px]">
          <Image src={veliFoto} alt="Anne ve çocuk" class="h-full w-full object-cover" />
        </div>

      </div>
    </div>
  </div>
</section>
