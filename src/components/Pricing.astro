---
import Icon from './Icon.astro';
import { UYELIK_URL } from '../config';

const ozellikler = [
  { baslik: 'Canlı Etüt',                          aciklama: 'Branş öğretmenleri gözetiminde canlı konu ve uygulama etütleri.', ikon: 'users',  renk: 'bg-turkuaz'   },
  { baslik: 'Canlı Soru-Cevap Dersi',              aciklama: 'Uzman öğretmenlerle sorun oluşturan sorular cevaplanır.',        ikon: 'flask',  renk: 'bg-mercan'    },
  { baslik: 'Gerçek Koçluk',                       aciklama: 'Rehber öğretmenlerle kişisel gelişim takibi ve destek.',         ikon: 'target', renk: 'bg-mor'       },
  { baslik: 'Yapay Zekâ Takibi',                   aciklama: 'Etütlerdeki her performans yapay zekâ ile izlenir.',             ikon: 'cpu',    renk: 'bg-lacivert'  },
  { baslik: 'Akıllı Öğretim Ekosistemi',           aciklama: 'Videolu konu anlatımı, soru çözümü ve deneme testleri.',         ikon: 'video',  renk: 'bg-mavi'      },
  { baslik: 'Deneme Kulübü',                       aciklama: 'Her döneme özel adresinize basılı deneme paketi.',               ikon: 'mail',   renk: 'bg-[#06B6D4]' },
  { baslik: 'Veli Raporlama',                      aciklama: 'Kişisel gelişim ve ders durumu düzenli raporlanır.',             ikon: 'bell',   renk: 'bg-mercan'    },
  { baslik: 'MEB Kaynakları Ödevlendirme ve Analizi', aciklama: 'MEB içerikleri ödevlendirilir, analizi yapılır.',            ikon: 'book',   renk: 'bg-mor'       },
  { baslik: 'Veli Rehberliği',                     aciklama: 'Akademisyen danışmanlığında seminer ve atölyeler.',              ikon: 'users',  renk: 'bg-turkuaz'   },
];
---

<section id="uyelik" class="bg-white px-6 pb-6 pt-0 md:px-10 md:pb-8">
  <div class="mx-auto max-w-[1400px]">
    <div class="reveal rounded-[8px] bg-bulut px-6 py-10 md:px-10 md:py-12">

      <div class="mb-8 text-center">
        <h2 class="font-baslik text-2xl font-bold text-[#1b2a5b] md:text-3xl">Tek Plan, Tam Erişim</h2>
        <p class="mt-2 text-sm text-[#5b6488]">İhtiyacın olan her şey bir arada.</p>
      </div>

      <!-- Yatay kart: sol 1/3 fiyat, sağ 2/3 özellikler -->
      <div class="rounded-[8px] border border-kenar bg-beyaz shadow-yumusak">
        <div class="grid gap-0 md:grid-cols-[1fr_1px_2fr]">

          <!-- Sol: rozet + fiyat -->
          <div class="p-8 md:p-10">
            <span class="inline-flex items-center rounded-md bg-gradient-to-r from-[#7c5cfc]/12 to-[#3b6ef0]/12 px-3 py-1 text-xs font-semibold text-[#3b6ef0]">
              2027 LGS Hazırlık
            </span>
            <p class="mt-6 font-baslik text-4xl font-extrabold text-[#1b2a5b] sm:text-5xl">
              54.945 <span class="text-2xl font-bold sm:text-3xl">TL</span>
            </p>
            <p class="mt-2 text-sm text-[#5b6488]">Tüm kartlara 9 taksit</p>

            <a
              href={UYELIK_URL}
              class="mt-8 inline-flex w-full items-center justify-center rounded-[8px] bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] px-6 py-3 text-sm font-semibold text-beyaz shadow-[0_8px_20px_rgba(80,90,240,.30)] transition hover:brightness-105"
            >
              Ücretsiz Deneyim
            </a>
          </div>

          <!-- Dikey ayraç -->
          <div class="hidden bg-kenar md:block"></div>

          <!-- Sağ: özellikler -->
          <div class="border-t border-kenar p-8 md:border-t-0 md:p-10">
            <p class="text-xs font-semibold uppercase tracking-widest text-[#5b6488]">Tam Erişime Dahil Olanlar</p>
            <ul class="mt-6 grid gap-5 sm:grid-cols-2">
              {ozellikler.map((o) => (
                <li class="flex items-start gap-4">
                  <span class={`grid h-10 w-10 shrink-0 place-items-center rounded-[8px] text-beyaz ${o.renk}`}>
                    <Icon name={o.ikon} size={20} />
                  </span>
                  <div>
                    <p class="text-sm font-semibold text-[#1b2a5b]">{o.baslik}</p>
                    <p class="mt-0.5 text-xs leading-relaxed text-[#5b6488]">{o.aciklama}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>
