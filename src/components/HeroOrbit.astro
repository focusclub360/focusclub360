---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import { UYELIK_URL } from '../config';
import heroGorsel from '../assets/hero-masaustu.jpg';

// Yörüngede dönen ve merkezde öne çıkan 4 özellik
const ozellikler = [
  { baslik: 'Canlı Etüt', alt: 'Branş öğretmeni gözetiminde', ikon: 'users' },
  { baslik: 'Canlı Soru Çözümü', alt: 'Etüt esnasında soruların çözülmesi', ikon: 'flask' },
  { baslik: 'Gerçek Koçluk', alt: 'Birebir destek veren rehber öğretmen', ikon: 'target' },
  { baslik: 'Online Ders İçerikleri', alt: 'Bütün müfredat', ikon: 'book' },
];

const chipler = [
  { deger: '5.920 dk', etiket: 'Ders anlatım videosu' },
  { deger: '4.440 dk', etiket: 'Soru çözüm videosu' },
  { deger: '120+', etiket: 'Öğretmen' },
  { deger: '10.134', etiket: 'Soru' },
];

// Halka üzerindeki dekoratif noktaların yüzde konumları (45° köşeler)
const halkaNoktalari = [
  { left: '85.36%', top: '14.64%' },
  { left: '85.36%', top: '85.36%' },
  { left: '14.64%', top: '85.36%' },
  { left: '14.64%', top: '14.64%' },
];
---

<div class="flex min-h-[calc(100vh-8rem)] flex-col md:min-h-[calc(100vh-9rem)]">

    <!-- Hero gövdesi (kalan alanı doldurur) -->
    <div class="flex min-h-0 flex-1 flex-col px-6 pb-4 md:px-10 md:pb-6">
      <div class="max-w-2xl">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-gradient-to-r from-[#7c5cfc]/12 to-[#3b6ef0]/12 px-3 py-1 text-xs font-semibold text-[#3b6ef0] md:text-sm">
          <Icon name="star" size={14} class="text-[#7c5cfc]" />
          Türkiye'nin İlk ve Tek Dijital Etüt Kulübü
        </span>
        <h1 class="mt-3 font-baslik text-3xl font-extrabold leading-[1.12] tracking-tight text-[#1b2a5b] md:text-5xl lg:text-[3.2rem]">
          Çocuğunuz verimli
          <span class="inline-block bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] bg-clip-text pb-1 pr-4 font-bold italic text-transparent">çalışıyor mu?</span>
        </h1>
        <p class="mt-2 text-base text-[#5b6488] md:text-lg">
          Çocuğunuzun akademik gelişimini tek panelden takip edin.
        </p>
      </div>

      <!-- Radiuslu mavi banner -->
      <div class="relative mt-4 min-h-0 flex-1 overflow-hidden rounded-[8px]">
        <!-- Arka plan görseli (çocuk) -->
        <Image
          src={heroGorsel}
          alt="Tabletten canlı etüte katılan öğrenci"
          widths={[768, 1280, 1600]}
          sizes="100vw"
          class="absolute inset-0 h-full w-full object-cover object-center"
          loading="eager"
        />
        <!-- Mavi katman -->
        <div class="absolute inset-0" style="background:linear-gradient(135deg, rgba(59,110,240,0.82), rgba(42,79,208,0.90));"></div>

        <!-- Yörünge -->
        <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
          <div class="fc-orbit relative h-[320px] w-[320px] md:h-[420px] md:w-[420px]">
            <div class="absolute inset-0 rounded-full border-2 border-dashed border-white/45"></div>
            {halkaNoktalari.map((n) => (
              <span class="absolute h-2 w-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white/70" style={`left:${n.left};top:${n.top}`}></span>
            ))}

            <!-- dönen özellik düğümleri -->
            {ozellikler.map((o, i) => (
              <div class="fc-node absolute left-1/2 top-1/2 z-10 flex flex-col items-center" data-i={i}>
                <span class="fc-node-daire grid h-11 w-11 place-items-center rounded-full bg-gradient-to-br from-[#60a5fa] to-[#3b6ef0] text-beyaz shadow-lg ring-4 ring-white/30 transition-all md:h-14 md:w-14">
                  <Icon name={o.ikon} size={22} />
                </span>
              </div>
            ))}

            <!-- merkezdeki "öne çıkan" kart (büyük) -->
            <div class="absolute left-1/2 top-1/2 z-20 w-[230px] -translate-x-1/2 -translate-y-1/2 rounded-kart bg-white/95 p-4 shadow-[0_24px_60px_rgba(20,40,120,.35)] backdrop-blur md:w-[290px]">
              <div class="relative flex min-h-[60px] items-center md:min-h-[68px]">
                {ozellikler.map((o, i) => (
                  <div class="fc-ozellik w-full items-center gap-3" data-i={i} style={i === 0 ? 'display:flex' : 'display:none'}>
                    <span class="grid h-11 w-11 shrink-0 place-items-center rounded-kart bg-gradient-to-br from-[#60a5fa] to-[#3b6ef0] text-beyaz md:h-12 md:w-12">
                      <Icon name={o.ikon} size={24} />
                    </span>
                    <div class="min-w-0">
                      <p class="font-baslik text-base font-bold leading-tight text-[#1b2a5b] md:text-lg">{o.baslik}</p>
                      <p class="mt-0.5 text-xs leading-snug text-[#6b76a0] md:text-sm">{o.alt}</p>
                    </div>
                  </div>
                ))}
              </div>
              <div class="mt-4 flex justify-center gap-2">
                {ozellikler.map((_, i) => (
                  <span class="fc-nokta h-1.5 w-1.5 rounded-full bg-[#dfe5f5]" data-i={i}></span>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Alt sol: not + buton -->
        <div class="absolute bottom-5 left-5 right-5 flex flex-col items-start gap-4 md:bottom-7 md:left-8 md:right-8 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="mb-2 max-w-xs text-sm font-medium text-white/90">
              2 hafta boyunca ücretsiz deneyim.
            </p>
            <a
              href={UYELIK_URL}
              class="inline-flex items-center gap-3 rounded-buton bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] py-2.5 pl-6 pr-2.5 font-semibold text-beyaz shadow-[0_12px_30px_rgba(40,40,120,.35)] transition hover:brightness-105"
            >
              Ücretsiz Üye Ol
              <span class="grid h-9 w-9 place-items-center rounded-full bg-white text-[#3b6ef0]">
                <Icon name="arrow" size={18} />
              </span>
            </a>
          </div>

          <!-- Alt sağ: istatistik çipleri -->
          <div class="grid grid-cols-2 gap-2.5">
            {chipler.map((c) => (
              <span class="rounded-kart bg-white/95 px-3.5 py-2 shadow">
                <span class="block font-baslik text-base font-bold text-[#1b2a5b]">{c.deger}</span>
                <span class="block text-xs text-[#6b76a0]">{c.etiket}</span>
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
</div>

<style>
  .fc-node {
    transition: transform 0.9s cubic-bezier(0.65, 0, 0.35, 1);
    transform: translate(-50%, -50%);
  }
  .fc-node-daire {
    opacity: 0.7;
    transform: scale(0.82);
  }
  .fc-node.aktif .fc-node-daire {
    opacity: 1;
    transform: scale(1.12);
    box-shadow: 0 14px 30px rgba(20, 40, 120, 0.45);
  }
  .fc-ozellik {
    transition: opacity 0.4s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    .fc-node {
      transition: none;
    }
  }
</style>

<script>
  const orbit = document.querySelector<HTMLElement>('.fc-orbit');
  if (orbit) {
    const nodes = Array.from(orbit.querySelectorAll<HTMLElement>('.fc-node'));
    const ozellikler = Array.from(orbit.querySelectorAll<HTMLElement>('.fc-ozellik'));
    const noktalar = Array.from(orbit.querySelectorAll<HTMLElement>('.fc-nokta'));
    const N = nodes.length;
    let adim = 0;

    const yaricap = () => orbit.clientWidth / 2;

    function yerlesim() {
      const r = yaricap();
      nodes.forEach((node, i) => {
        const aci = i * 90 + adim * 90;
        node.style.transform = `translate(-50%,-50%) rotate(${aci}deg) translateY(-${r}px) rotate(${-aci}deg)`;
      });
    }

    function vurgula() {
      const aktif = ((2 - adim) % N + N) % N;
      nodes.forEach((node, i) => node.classList.toggle('aktif', i === aktif));
      ozellikler.forEach((el, i) => {
        el.style.display = i === aktif ? 'flex' : 'none';
      });
      noktalar.forEach((nokta, i) => {
        nokta.classList.toggle('bg-[#3b6ef0]', i === aktif);
        nokta.classList.toggle('w-4', i === aktif);
        nokta.classList.toggle('bg-[#dfe5f5]', i !== aktif);
      });
    }

    yerlesim();
    vurgula();
    window.addEventListener('resize', yerlesim);

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      window.setInterval(() => {
        adim += 1;
        yerlesim();
        vurgula();
      }, 3200);
    }
  }
</script>
