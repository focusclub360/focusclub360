---
import Icon from './Icon.astro';
import { ROUTES } from '../config';

const kartlar = [
  { baslik: 'Canlı Etüt', aciklama: 'Branş öğretmenleriyle canlı etütler', ikon: 'users' },
  { baslik: 'Canlı Soru Çözüm', aciklama: 'Sorular anında çözülür', ikon: 'flask' },
  { baslik: 'Gerçek Koçluk', aciklama: 'Kişisel koçun yolunu açar', ikon: 'target' },
  { baslik: 'Yapay Zekâ Takibi ve Veli Raporlaması', aciklama: 'Şeffaf takip ve raporlar', ikon: 'cpu' },
  { baslik: 'Online Ders İçerikleri', aciklama: '5.920 dk anlatım, 10.134 video çözümlü soru', ikon: 'video' },
  { baslik: 'Motivasyon ve Rozetler', aciklama: 'Katılım ve ödevler puanlanır, rozet kazanılır', ikon: 'award' },
];
---

<section class="bg-white py-16 md:py-24">
  <div class="mx-auto max-w-[1400px] px-6 md:px-10">
    <div class="reveal mx-auto max-w-2xl text-center">
      <h2 class="font-baslik text-3xl font-bold text-[#1b2a5b] md:text-4xl">FocusClub 360 Ne Sunuyor?</h2>
      <p class="mt-3 text-lg text-[#5b6488]">Size başarıyı kazandıracak sistem sunuyoruz.</p>
    </div>

    <div class="reveal mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {kartlar.map((k) => (
        <article class="group flex flex-col rounded-[20px] border border-[#e7ecf2] bg-white p-6 shadow-[0_10px_30px_rgba(60,80,180,.06)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_20px_45px_rgba(60,80,180,.12)]">
          <span class="grid h-12 w-12 place-items-center rounded-2xl bg-gradient-to-br from-[#60a5fa] to-[#3b6ef0] text-beyaz">
            <Icon name={k.ikon} size={24} />
          </span>
          <h3 class="mt-4 font-baslik text-lg font-semibold leading-snug text-[#1b2a5b]">{k.baslik}</h3>
          <p class="mt-2 flex-1 text-sm text-[#6b76a0]">{k.aciklama}</p>
          <a
            href={ROUTES.kulupteNelerVar}
            class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-[#3b6ef0] transition group-hover:gap-2"
          >
            Detayları İncele
            <Icon name="arrow" size={15} />
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
