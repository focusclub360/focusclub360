---
import Icon from './Icon.astro';

const yorumlar = [
  {
    metin: 'Oğlumun düzenli çalışması için aradığımız her şey burada. Raporlar sayesinde içim çok rahat.',
    isim: 'Ayşe K.',
    rol: 'Anne',
  },
  {
    metin: 'Koçumuz gerçekten çok ilgili. Soru çözümlerindeki hızlanma fark edilir düzeyde.',
    isim: 'Mehmet T.',
    rol: 'Baba',
  },
  {
    metin: 'Eskiden ikna etmek zordu, şimdi kendi isteğiyle etüde katılıyor. Büyük değişim.',
    isim: 'Zeynep D.',
    rol: 'Anne',
  },
];
---

<section class="konteyner py-16 md:py-24">
  <div class="reveal mx-auto max-w-2xl text-center">
    <h2 class="font-baslik text-3xl font-bold md:text-4xl">Anne Babalar Ne Diyor</h2>
  </div>

  <div class="reveal mt-12 grid gap-6 md:grid-cols-3">
    {yorumlar.map((y) => (
      <figure class="flex flex-col rounded-kart border border-kenar bg-beyaz p-6 shadow-kucuk transition duration-300 hover:-translate-y-1 hover:shadow-yumusak">
        <div class="flex gap-1 text-turkuaz" aria-label="5 üzerinden 5 yıldız">
          {Array.from({ length: 5 }).map(() => <Icon name="star" size={18} />)}
        </div>
        <blockquote class="mt-4 flex-1 text-lacivert">“{y.metin}”</blockquote>
        <figcaption class="mt-5 border-t border-kenar pt-4">
          <span class="font-semibold text-lacivert">{y.isim}</span>
          <span class="text-sm text-gri">, {y.rol}</span>
        </figcaption>
      </figure>
    ))}
  </div>
</section>
