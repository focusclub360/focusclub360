---
import Icon from './Icon.astro';
import { UYELIK_URL, KAYIT_URL, ROUTES } from '../config';

const sutunlar = [
  {
    baslik: 'Kulüp',
    linkler: [
      { ad: 'Etüt Kulübü Nedir',  href: ROUTES.kulupteNelerVar },
      { ad: 'Kulüpte Neler Var',  href: ROUTES.kulupteNelerVar },
      { ad: 'Nasıl Çalışır',      href: ROUTES.nasilCalisir    },
      { ad: 'Velilere',           href: ROUTES.velilere         },
    ],
  },
  {
    baslik: 'Üyelik',
    linkler: [
      { ad: 'Nasıl Üye Olunur',       href: ROUTES.nasilUyeOlunur },
      { ad: '2 Hafta Ücretsiz Deneyim', href: UYELIK_URL           },
      { ad: 'Üye Olun',               href: KAYIT_URL              },
    ],
  },
  {
    baslik: 'Destek',
    linkler: [
      { ad: 'Merak Edilenler', href: ROUTES.merakEdilenler },
      { ad: 'Bize Ulaşın',    href: ROUTES.bizeUlasin },
      { ad: 'Rehber',         href: ROUTES.rehber     },
    ],
  },
  {
    baslik: 'İletişim',
    linkler: [
      { ad: 'info@focusclub360.com', href: 'mailto:info@focusclub360.com' },
      { ad: 'YTÜ Teknokent, İstanbul', href: ROUTES.bizeUlasin            },
    ],
  },
];

const sosyal = [
  { ad: 'Instagram', ikon: 'instagram', href: '#' },
  { ad: 'YouTube',   ikon: 'youtube',   href: '#' },
  { ad: 'X',         ikon: 'twitter',   href: '#' },
  { ad: 'TikTok',    ikon: 'tiktok',    href: '#' },
];
---

<footer class="rounded-b-[8px] bg-lacivert px-6 py-12 text-beyaz/60 md:px-10 md:py-14">
  <div class="mx-auto max-w-[1400px]">

    <!-- Üst alan: sütunlar sol, sosyal ikonlar sağ -->
    <div class="flex flex-col gap-10 lg:flex-row lg:justify-between">

      <!-- Link sütunları -->
      <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
        {sutunlar.map((c) => (
          <div>
            <h3 class="font-baslik text-sm font-bold text-beyaz">{c.baslik}</h3>
            <ul class="mt-4 space-y-3 text-sm">
              {c.linkler.map((l) => (
                <li>
                  <a href={l.href} class="transition-colors hover:text-beyaz">{l.ad}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Sosyal ikonlar -->
      <div class="flex shrink-0 items-start gap-3 lg:justify-end">
        {sosyal.map((s) => (
          <a
            href={s.href}
            aria-label={s.ad}
            class="grid h-10 w-10 place-items-center rounded-full bg-beyaz/10 text-beyaz/70 transition hover:bg-beyaz/20 hover:text-beyaz"
          >
            <Icon name={s.ikon} size={18} />
          </a>
        ))}
      </div>

    </div>

    <!-- Alt satır -->
    <div class="mt-14 flex flex-col items-start justify-between gap-6 border-t border-beyaz/10 pt-8 lg:flex-row lg:items-end">

      <!-- Sol: telif + yasal -->
      <div class="space-y-2">
        <p class="text-sm text-beyaz/50">© 2026 FocusClub 360. Tüm hakları saklıdır.</p>
        <div class="flex flex-wrap gap-4 text-sm text-beyaz/40">
          <a href="/gizlilik" class="hover:text-beyaz">Gizlilik Politikası</a>
          <a href="/kvkk" class="hover:text-beyaz">KVKK Aydınlatma Metni</a>
          <button type="button" data-cc-open class="hover:text-beyaz">Çerez Ayarları</button>
        </div>
      </div>

      <!-- Sağ: büyük marka logosu (eski watermark hizasında, alta hizalı) -->
      <img src="/FocusClub360_logoF_navy-footer.png" alt="FocusClub 360" class="block h-10 w-auto opacity-90 sm:h-14 lg:h-[72px]" />

    </div>
  </div>
</footer>
