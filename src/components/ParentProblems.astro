---
import Icon from './Icon.astro';

const sorunlar = [
  { metin: 'Telefon dikkati dağıtıyor', ikon: 'smartphone' },
  { metin: 'Veli sürekli hatırlatmak zorunda kalıyor', ikon: 'bell' },
  { metin: 'Ödevler son dakikaya kalıyor', ikon: 'clock' },
  { metin: 'Düzenli çalışma alışkanlığı oluşmuyor', ikon: 'list' },
  { metin: 'Çalışıyor mu çalışmıyor mu tam takip edilemiyor', ikon: 'eye' },
];
---

<section class="konteyner py-16 md:py-24">
  <div class="reveal mx-auto max-w-2xl text-center">
    <h2 class="font-baslik text-3xl font-bold md:text-4xl">
      Anne babaların ders çalıştırma sorunlarını çözüyoruz
    </h2>
  </div>

  <div class="reveal mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-5">
    {sorunlar.map((s) => (
      <div class="flex flex-col items-center rounded-kart border border-kenar bg-beyaz p-5 text-center shadow-kucuk">
        <span class="grid h-12 w-12 place-items-center rounded-full bg-mercan/10 text-mercan">
          <Icon name={s.ikon} size={22} />
        </span>
        <p class="mt-3 text-sm font-medium text-lacivert">{s.metin}</p>
      </div>
    ))}
  </div>

  <p class="reveal mt-10 text-center font-baslik text-lg font-semibold text-lacivert">
    FocusClub 360 tam da bu sorunları çözmek için var.
  </p>
</section>
