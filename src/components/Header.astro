---
import Icon from './Icon.astro';
import Logo from './Logo.astro';
import { UYELIK_URL, GIRIS_URL, ROUTES } from '../config';

const menu = [
  { ad: 'Kulüpte Neler Var', href: ROUTES.kulupteNelerVar },
  { ad: 'Nasıl Çalışır', href: ROUTES.nasilCalisir },
  { ad: 'Velilere', href: ROUTES.velilere },
  { ad: 'Nasıl Üye Olunur', href: ROUTES.nasilUyeOlunur },
  { ad: 'Rehber', href: ROUTES.rehber },
];
---

<header id="site-header" class="sticky top-0 z-50 pt-3 transition-all duration-300">
  <div class="konteyner">
    <div
      id="header-card"
      class="flex items-center justify-between gap-4 rounded-bant border border-kenar bg-beyaz/90 px-5 py-3 shadow-kucuk backdrop-blur transition-all duration-300"
    >
      <Logo />

      <nav class="hidden items-center gap-7 lg:flex" aria-label="Ana menü">
        {menu.map((m) => <a href={m.href} class="menu-link text-sm">{m.ad}</a>)}
      </nav>

      <div class="hidden items-center gap-3 lg:flex">
        <a href={GIRIS_URL} class="btn-outline px-4 py-2 text-sm">
          <Icon name="user" size={17} />
          Kulübe Giriş
        </a>
        <a href={UYELIK_URL} class="btn-amber px-4 py-2 text-sm">2 Hafta Ücretsiz Keşfet</a>
      </div>

      <button
        type="button"
        id="menu-ac"
        class="rounded-buton border border-kenar p-2 text-lacivert lg:hidden"
        aria-label="Menüyü aç"
        aria-expanded="false"
        aria-controls="mobil-menu"
      >
        <Icon name="menu" size={22} />
      </button>
    </div>
  </div>

  <!-- Mobil menü -->
  <div
    id="mobil-menu"
    class="hidden border-b border-kenar bg-beyaz lg:hidden"
  >
    <nav class="konteyner flex flex-col gap-1 py-4" aria-label="Mobil menü">
      {menu.map((m) => (
        <a href={m.href} class="rounded-buton px-3 py-3 font-medium text-lacivert hover:bg-bulut" data-mobil-link>{m.ad}</a>
      ))}
      <div class="mt-3 flex flex-col gap-3">
        <a href={GIRIS_URL} class="btn-outline w-full" data-mobil-link>
          <Icon name="user" size={17} /> Kulübe Giriş
        </a>
        <a href={UYELIK_URL} class="btn-amber w-full" data-mobil-link>2 Hafta Ücretsiz Keşfet</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const acBtn = document.getElementById('menu-ac');
  const menu = document.getElementById('mobil-menu');
  const linkler = document.querySelectorAll('[data-mobil-link]');

  function kapat() {
    menu?.classList.add('hidden');
    acBtn?.setAttribute('aria-expanded', 'false');
  }
  acBtn?.addEventListener('click', () => {
    const acik = !menu?.classList.contains('hidden');
    if (acik) {
      kapat();
    } else {
      menu?.classList.remove('hidden');
      acBtn?.setAttribute('aria-expanded', 'true');
    }
  });
  linkler.forEach((l) => l.addEventListener('click', kapat));

  // Scroll'da header küçülür + gölge
  const header = document.getElementById('header-card');
  const onScroll = () => {
    if (window.scrollY > 12) {
      header?.classList.add('shadow-yumusak', '!py-2');
    } else {
      header?.classList.remove('shadow-yumusak', '!py-2');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
