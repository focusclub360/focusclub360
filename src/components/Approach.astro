---
import Icon from './Icon.astro';
import { Image } from 'astro:assets';
import yaklasimGorsel from '../assets/yaklasim-anasayfa.jpg';

const liste = [
  'Haftada 4 gün canlı etüt ile planlı çalışma alışkanlığı kazandırır.',
  'Bireylere özel çalışma ile dikkat dağınıklığını azaltır.',
  'Yapay zeka takibi ile eksikleri zamanında tespit eder.',
  'Bireysel rehber öğretmen koçluğu ile motivasyonu ve özgüveni artırır.',
  'Veli bilgilendirme raporları ile sürekli takip ve geri bildirim sağlar.',
];
---

<section class="bg-[#f5f8ff] py-16 md:py-24">
  <div class="mx-auto grid max-w-[1400px] items-center gap-12 px-6 md:px-10 lg:grid-cols-2">
    <!-- Sol: metin -->
    <div class="reveal">
      <span class="inline-flex items-center gap-1.5 rounded-md bg-gradient-to-r from-[#7c5cfc]/12 to-[#3b6ef0]/12 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-[#3b6ef0]">
        Akademik Yaklaşımımız
      </span>
      <h2 class="mt-4 font-baslik text-3xl font-bold leading-tight text-[#1b2a5b] md:text-4xl">
        Çocuğunuzun ihtiyacı daha fazla kaynak değil; onu her gün çalıştıran bir düzen ve yanında gerçek bir ekiptir.
      </h2>

      <p class="mt-8 font-baslik text-base font-bold text-[#3b6ef0]">FocusClub 360;</p>

      <ul class="mt-3 space-y-3.5">
        {liste.map((m) => (
          <li class="flex items-start gap-3">
            <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-gradient-to-br from-[#7c5cfc] to-[#3b6ef0] text-beyaz">
              <Icon name="check" size={14} />
            </span>
            <span class="text-[#1b2a5b]">{m}</span>
          </li>
        ))}
      </ul>

      <p class="mt-8 font-baslik text-3xl font-bold leading-tight text-[#1b2a5b] md:text-4xl">
        Siz ders çalıştırmaya değil, çocuğunuzun gelişimini izlemeye odaklanın.
      </p>
    </div>

    <!-- Sağ: görsel -->
    <div class="reveal">
      <Image
        src={yaklasimGorsel}
        alt="Akademik yaklaşım görseli"
        widths={[640, 1024]}
        sizes="(max-width: 1024px) 100vw, 50vw"
        class="aspect-[4/3] w-full rounded-[8px] object-cover shadow-yumusak"
      />
    </div>
  </div>
</section>
