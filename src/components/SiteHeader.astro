---
import Icon from './Icon.astro';
import { UYELIK_URL, KAYIT_URL, ROUTES } from '../config';

interface Props {
  aktif?: string; // aktif menü öğesinin href'i (opsiyonel)
}
const { aktif } = Astro.props;

const menu = [
  { ad: 'Kulüpte Neler Var', href: ROUTES.kulupteNelerVar },
  { ad: 'Nasıl Çalışır',     href: ROUTES.nasilCalisir    },
  { ad: 'Velilere',          href: ROUTES.velilere        },
  { ad: 'Nasıl Üye Olunur',  href: ROUTES.nasilUyeOlunur  },
  { ad: 'Rehber',            href: ROUTES.rehber          },
];
---

<div class="sticky top-0 z-50">
  <div class="flex items-center justify-center gap-2 bg-gradient-to-r from-[#2D3AAE] to-[#5060E0] px-4 py-2 text-center text-sm font-medium text-beyaz md:rounded-t-[8px]">
    <Icon name="gift" size={16} />
    Ücretsiz İki Hafta Deneyim Fırsatı
  </div>

  <header class="flex items-center justify-between gap-4 px-6 py-3 backdrop-blur-sm md:py-4 md:px-10" style="background-color: rgba(27,33,64,0.97);">
    <a href="/" class="flex items-center" aria-label="FocusClub 360"><img src="/FocusClub360_logoF_navy.png" alt="FocusClub 360" class="h-[54px] w-auto md:h-[72px]" /></a>

    <nav class="hidden items-center gap-7 lg:flex">
      {menu.map((m) => (
        <a
          href={m.href}
          class={`text-sm transition ${m.href === aktif ? 'font-semibold text-[#FFFFFF]' : 'font-medium text-[#8B96CC] hover:text-[#FFFFFF]'}`}
        >{m.ad}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <a href={KAYIT_URL} class="hidden text-sm font-semibold text-[#FFFFFF] hover:opacity-70 sm:block">Üye Olun</a>
      <a
        href={UYELIK_URL}
        class="hidden rounded-buton bg-gradient-to-r from-[#6E7CFF] to-[#2D3AAE] px-5 py-2.5 text-sm font-semibold text-beyaz shadow-[0_8px_20px_rgba(110,124,255,.40)] transition hover:brightness-110 sm:inline-block"
      >2 Hafta Ücretsiz</a>
      <button id="mob-tog" aria-label="Menüyü aç" class="grid h-9 w-9 shrink-0 place-items-center rounded-[8px] border border-kenar text-[#FFFFFF] transition hover:bg-bulut focus:outline-none active:bg-[#1E2848] lg:hidden" style="-webkit-tap-highlight-color: transparent; background-color: #1B2140; -webkit-appearance: none; appearance: none;">
        <Icon name="menu" size={20} />
      </button>
    </div>
  </header>

  <nav id="mob-nav" class="hidden border-b border-kenar px-6 pb-5 pt-2 lg:hidden" style="background-color: #1B2140;">
    <div class="flex flex-col">
      {menu.map((m) => (
        <a href={m.href} class="mob-link rounded-[8px] px-3 py-2.5 text-sm font-medium text-[#8B96CC] transition hover:bg-bulut hover:text-[#FFFFFF]">{m.ad}</a>
      ))}
      <a href={KAYIT_URL} class="mob-link rounded-[8px] px-3 py-2.5 text-sm font-medium text-[#8B96CC] transition hover:bg-bulut hover:text-[#FFFFFF]">Üye Olun</a>
    </div>
    <a
      href={UYELIK_URL}
      class="mt-3 flex items-center justify-center gap-2 rounded-[8px] bg-gradient-to-r from-[#6E7CFF] to-[#2D3AAE] py-3 text-sm font-semibold text-beyaz"
    >
      2 Hafta Ücretsiz Dene
      <Icon name="arrow" size={16} />
    </a>
  </nav>
</div>

<script>
  const tog = document.getElementById('mob-tog');
  const nav = document.getElementById('mob-nav');
  tog?.addEventListener('click', () => { nav?.classList.toggle('hidden'); });
  document.querySelectorAll('.mob-link').forEach((l) => {
    l.addEventListener('click', () => nav?.classList.add('hidden'));
  });
</script>
