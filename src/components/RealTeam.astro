---
import Icon from './Icon.astro';
import { Image } from 'astro:assets';
import tubitak from '../assets/tubitak-logo.jpg';
import ytuTeknopark from '../assets/ytu-teknopark-logo.png';

const kartlar = [
  { baslik: 'Gerçek Branş Öğretmeni', aciklama: 'Uzman branş öğretmeni canlı etütlerde yanınızda.',  ikon: 'users',  renk: 'bg-turkuaz' },
  { baslik: 'Yapay Zekâ Takibi',      aciklama: 'Her adımın akıllı analizle izlenir.',               ikon: 'cpu',    renk: 'bg-lacivert' },
  { baslik: 'Gerçek Başarı Koçu',     aciklama: 'Motivasyon ve hedef odaklı koçluk desteği.',        ikon: 'target', renk: 'bg-mor'      },
];
---

<section id="rehber" class="bg-white px-6 pb-6 pt-0 md:px-10 md:pb-8">
  <div class="mx-auto max-w-[1400px]">
    <div class="reveal rounded-[8px] bg-bulut px-6 py-12 md:px-10 md:py-14">

      <div class="mx-auto max-w-xl text-center">
        <h2 class="font-baslik text-2xl font-bold text-[#1b2a5b] md:text-3xl">Gerçek Ekip, Akıllı Takip</h2>
      </div>

      <!-- 3 dikey kart -->
      <div class="mt-8 grid gap-5 sm:grid-cols-3">
        {kartlar.map((k) => (
          <div class="flex flex-col items-center rounded-[8px] border border-kenar bg-beyaz p-6 text-center shadow-kucuk">
            <span class={`grid h-12 w-12 place-items-center rounded-[8px] text-beyaz ${k.renk}`}>
              <Icon name={k.ikon} size={22} />
            </span>
            <p class="mt-4 font-baslik text-sm font-semibold text-[#1b2a5b]">{k.baslik}</p>
            <p class="mt-1.5 text-xs leading-relaxed text-[#5b6488]">{k.aciklama}</p>
          </div>
        ))}
      </div>

      <!-- Logolar -->
      <div class="mt-6 flex items-center justify-center gap-6">
        <div class="flex items-center justify-center rounded-[8px] border border-kenar bg-beyaz px-6 py-3 shadow-kucuk">
          <Image src={tubitak} alt="TÜBİTAK" height={48} class="h-12 w-auto object-contain" />
        </div>
        <div class="flex items-center justify-center rounded-[8px] border border-kenar bg-beyaz px-6 py-3 shadow-kucuk">
          <Image src={ytuTeknopark} alt="YTÜ Teknopark" height={48} class="h-12 w-auto object-contain" />
        </div>
      </div>

    </div>
  </div>
</section>
