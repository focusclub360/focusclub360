---
import Icon from './Icon.astro';
import { ROUTES } from '../config';

const kartlar = [
  { baslik: 'Gerçek Branş Öğretmenleri', aciklama: 'Uzman branş öğretmenleri canlı etütlerde yanınızda.',  ikon: 'users',  renk: 'bg-turkuaz' },
  { baslik: 'Yapay Zekâ Takibi',      aciklama: 'Her adımın akıllı analizle izlenir.',               ikon: 'cpu',    renk: 'bg-lacivert' },
  { baslik: 'Gerçek Başarı Koçu',     aciklama: 'Rehber öğretmenler eşliğinde bireysel motivasyon ve destek.',        ikon: 'target', renk: 'bg-mor'      },
];
---

<section id="rehber" class="bg-white px-6 pb-6 pt-0 md:px-10 md:pb-8">
  <div class="mx-auto max-w-[1400px]">
    <div class="reveal rounded-[8px] bg-bulut px-6 py-12 md:px-10 md:py-14">

      <div class="mx-auto max-w-xl text-center">
        <h2 class="font-baslik text-2xl font-bold text-[#1b2a5b] md:text-3xl">Biz Bir Takımız, Hep Birlikte Başaracağız.</h2>
      </div>

      <!-- 3 dikey kart -->
      <div class="mt-8 grid gap-5 sm:grid-cols-3">
        {kartlar.map((k) => (
          <div class="flex flex-col items-center rounded-[8px] border border-kenar bg-beyaz p-6 text-center shadow-kucuk">
            <span class={`grid h-12 w-12 place-items-center rounded-[8px] text-beyaz ${k.renk}`}>
              <Icon name={k.ikon} size={22} />
            </span>
            <p class="mt-4 font-baslik text-sm font-semibold text-[#1b2a5b]">{k.baslik}</p>
            <p class="mt-1.5 text-xs leading-relaxed text-[#5b6488]">{k.aciklama}</p>
          </div>
        ))}
      </div>

      <!-- Buton -->
      <div class="mt-8 flex justify-center">
        <a href={ROUTES.kulupteNelerVar} class="inline-flex items-center gap-2 rounded-[8px] bg-[#1b2a5b] px-6 py-3 font-baslik text-sm font-semibold text-beyaz shadow-kucuk transition hover:opacity-90">
          Kulüpte Neler Var?
          <span class="-rotate-90 inline-block"><Icon name="chevron" size={14} /></span>
        </a>
      </div>

    </div>
  </div>
</section>
