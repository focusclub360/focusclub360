---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import { UYELIK_URL } from '../config';
import heroGorsel from '../assets/hero-masaustu.jpg';

const ozellikler = [
  { baslik: 'Canlı Etüt',             alt: 'Branş Öğretmenleri Gözetiminde',        ikon: 'users',  renk: 'bg-turkuaz' },
  { baslik: 'Canlı Soru Çözüm',       alt: 'Öğretmenler Eşliğinde Çözüm',          ikon: 'flask',  renk: 'bg-mercan'  },
  { baslik: 'Gerçek Koçluk',          alt: 'Rehber Öğretmenlerle Bireysel',        ikon: 'target', renk: 'bg-mor'     },
  { baslik: 'Dijital Ders İçerikleri', alt: 'LGS Tüm Dersler',                      ikon: 'video',  renk: 'bg-mavi'    },
];
---

<div class="flex min-h-[calc(100svh-8rem)] flex-col md:min-h-[calc(100vh-9rem)]">
  <div class="flex min-h-0 flex-1 flex-col px-6 pb-4 md:px-10 md:pb-6">

    <!-- Badge — banner dışında beyaz alanda -->
    <div class="pb-2 pt-3 md:pb-3 md:pt-4">
      <span class="flex w-full items-center gap-1 rounded-md bg-[#ede8ff] px-2.5 py-1 text-[11px] font-semibold text-[#3b6ef0] md:inline-flex md:w-auto md:gap-1.5 md:bg-gradient-to-r md:from-[#7c5cfc]/12 md:to-[#3b6ef0]/12 md:px-3 md:py-1 md:text-sm">
        <Icon name="star" size={12} class="text-[#7c5cfc] md:size-[14px]" />
        Türkiye'nin İlk ve Tek Dijital Akademik Etüt Kulübü
      </span>
    </div>

    <!-- Banner -->
    <div class="relative min-h-0 flex-1 overflow-hidden rounded-[8px]">
      <!-- Fotoğraf -->
      <Image
        src={heroGorsel}
        alt="Tabletten canlı etüte katılan öğrenci"
        widths={[768, 1280, 1600]}
        sizes="100vw"
        class="absolute inset-0 h-full w-full object-cover object-center"
        loading="eager"
      />
      <!-- Overlay: mobilde düzgün, masaüstünde soldan sağa gradient -->
      <div class="absolute inset-0 bg-[rgba(28,55,185,0.75)] md:hidden"></div>
      <div class="hero-desktop-overlay absolute inset-0 hidden md:block"></div>

      <!-- İçerik katmanı -->
      <div class="absolute inset-0 z-10 flex flex-col justify-evenly px-5 py-4 md:px-10 md:py-10">

        <!-- Üst: başlık + alt yazı (masaüstünde kartlar da dahil) -->
        <div class="max-w-md">
          <h1 class="font-baslik text-2xl font-extrabold tracking-tight text-white md:text-4xl lg:text-[2.8rem]" style="line-height: 1.2;">
            Velilik Yapın,<br class="md:hidden" /> Öğretmenlik Değil!
          </h1>
          <p class="mt-3 text-sm text-white/80 md:mt-1 md:text-base">
            Canlı Etütler, Dijital Dersler, Canlı Soru Çözüm Desteği, Akademik Takip ve Gerçek Koç ile Çocuğunuz Düzenli Çalışsın; Siz Sadece Gelişimini İzleyin.
          </p>

          <!-- Özellik kartları 2×2: masaüstünde bu blokta -->
          <div class="hidden md:mt-5 md:grid md:grid-cols-2 md:gap-3">
            {ozellikler.map((o) => (
              <div class="flex items-center gap-3 rounded-kart bg-white/95 px-4 py-3 shadow-md backdrop-blur-sm">
                <span class={`grid h-10 w-10 shrink-0 place-items-center rounded-cip text-white ${o.renk}`}>
                  <Icon name={o.ikon} size={20} />
                </span>
                <div class="min-w-0">
                  <p class="font-baslik text-sm font-bold leading-snug text-[#1b2a5b]">{o.baslik}</p>
                  <p class="line-clamp-2 text-xs leading-tight text-[#6b76a0]">{o.alt}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Özellik kartları 2×2: yalnızca mobilde ayrı blok (eşit boşluk için) -->
        <div class="grid grid-cols-2 gap-2 md:hidden">
          {ozellikler.map((o) => (
            <div class="flex items-start gap-2 rounded-kart bg-white/95 px-2.5 py-2 shadow-md backdrop-blur-sm">
              <span class={`mt-0.5 grid h-7 w-7 shrink-0 place-items-center rounded-cip text-white ${o.renk}`}>
                <Icon name={o.ikon} size={14} />
              </span>
              <div class="min-w-0">
                <p class="font-baslik text-xs font-bold leading-snug text-[#1b2a5b]">{o.baslik}</p>
                <p class="text-[10px] leading-tight text-[#6b76a0]" style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;">{o.alt}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Alt: CTA + not -->
        <div>
          <a
            href={UYELIK_URL}
            class="inline-flex items-center gap-2 rounded-buton bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] py-1.5 pl-4 pr-1.5 text-sm font-semibold text-beyaz shadow-[0_12px_30px_rgba(40,40,120,.35)] transition hover:brightness-105 md:gap-3 md:py-2.5 md:pl-6 md:pr-2.5 md:text-base"
          >
            Ücretsiz Deneyim
            <span class="grid h-7 w-7 place-items-center rounded-full bg-white text-[#3b6ef0] md:h-9 md:w-9">
              <Icon name="arrow" size={15} />
            </span>
          </a>
          <p class="mt-1 text-xs font-medium text-white/90 md:text-sm">
            2 Haftalık Ücretsiz Deneyim fırsatını kaçırmayın.
          </p>
        </div>

      </div>
    </div>
  </div>
</div>

<style is:global>
  .hero-desktop-overlay {
    background: linear-gradient(to right, rgba(30,60,200,0.82) 0%, rgba(30,60,200,0.60) 30%, rgba(30,60,200,0.22) 60%, rgba(30,60,200,0.06) 100%);
  }
</style>
