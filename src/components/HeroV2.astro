---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import { UYELIK_URL } from '../config';
import heroGorsel from '../assets/hero-masaustu.jpg';

const ozellikler = [
  { baslik: 'Canlı Etüt',             alt: 'Branş Öğretmeni Gözetiminde',          ikon: 'users',  renk: 'bg-turkuaz' },
  { baslik: 'Canlı Soru Çözüm',       alt: 'Anında çözüm',                         ikon: 'flask',  renk: 'bg-mercan'  },
  { baslik: 'Gerçek Koçluk',          alt: 'Birebir Rehber Öğretmen Eşliğinde',    ikon: 'target', renk: 'bg-mor'     },
  { baslik: 'Online Ders İçerikleri', alt: 'Tüm müfredat',                         ikon: 'video',  renk: 'bg-mavi'    },
];
---

<div class="flex min-h-[calc(100vh-8rem)] flex-col md:min-h-[calc(100vh-9rem)]">
  <div class="flex min-h-0 flex-1 flex-col px-6 pb-4 md:px-10 md:pb-6">

    <!-- Badge — banner dışında beyaz alanda -->
    <div class="pb-3 pt-4">
      <span class="inline-flex items-center gap-1.5 rounded-md bg-gradient-to-r from-[#7c5cfc]/12 to-[#3b6ef0]/12 px-3 py-1 text-xs font-semibold text-[#3b6ef0] md:text-sm">
        <Icon name="star" size={14} class="text-[#7c5cfc]" />
        Türkiye'nin İlk ve Tek Dijital Etüt Kulübü
      </span>
    </div>

    <!-- Banner -->
    <div class="relative min-h-0 flex-1 overflow-hidden rounded-[8px]">
      <!-- Fotoğraf -->
      <Image
        src={heroGorsel}
        alt="Tabletten canlı etüte katılan öğrenci"
        widths={[768, 1280, 1600]}
        sizes="100vw"
        class="absolute inset-0 h-full w-full object-cover object-center"
        loading="eager"
      />
      <!-- Overlay: solda yoğun mavi, sağda fotoğraf görünsün -->
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to right, rgba(30,60,200,0.82) 0%, rgba(30,60,200,0.60) 30%, rgba(30,60,200,0.22) 60%, rgba(30,60,200,0.06) 100%);"
      ></div>

      <!-- İçerik katmanı -->
      <div class="absolute inset-0 z-10 flex flex-col justify-evenly px-6 py-8 md:px-10 md:py-10">

        <!-- Üst: başlık + kartlar -->
        <div class="max-w-md">
          <h1 class="font-baslik text-2xl font-extrabold leading-tight tracking-tight text-white md:text-4xl lg:text-[2.8rem]">
            Çocuğunuz verimli
            <span class="font-bold italic text-white/90">çalışıyor mu?</span>
          </h1>
          <p class="mt-2 text-sm text-white/80 md:text-base">
            Çocuğunuzun akademik gelişimini tek panelden takip edin.
          </p>

          <!-- Özellik kartları 2×2 -->
          <div class="mt-5 grid grid-cols-2 gap-3">
            {ozellikler.map((o) => (
              <div class="flex h-16 items-center gap-3 rounded-kart bg-white/95 px-4 shadow-md backdrop-blur-sm md:h-[72px]">
                <span class={`grid h-10 w-10 shrink-0 place-items-center rounded-cip text-white ${o.renk}`}>
                  <Icon name={o.ikon} size={18} />
                </span>
                <div class="min-w-0">
                  <p class="font-baslik text-sm font-bold leading-snug text-[#1b2a5b]">{o.baslik}</p>
                  <p class="text-xs leading-tight text-[#6b76a0]">{o.alt}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Alt: not + CTA -->
        <div>
          <p class="mb-2 text-sm font-medium text-white/90">
            Ücretsiz üyelik için kredi kartı kaydetmeniz gerekmez.
          </p>
          <a
            href={UYELIK_URL}
            class="inline-flex items-center gap-3 rounded-buton bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] py-2.5 pl-6 pr-2.5 font-semibold text-beyaz shadow-[0_12px_30px_rgba(40,40,120,.35)] transition hover:brightness-105"
          >
            Ücretsiz Üye Ol
            <span class="grid h-9 w-9 place-items-center rounded-full bg-white text-[#3b6ef0]">
              <Icon name="arrow" size={18} />
            </span>
          </a>
        </div>

      </div>
    </div>
  </div>
</div>
