---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import { UYELIK_URL } from '../config';
import heroGorsel from '../assets/hero-masaustu.jpg';
---

<div class="flex min-h-[calc(100svh-8rem)] flex-col md:min-h-[calc(100vh-9rem)]">
  <div class="flex min-h-0 flex-1 flex-col px-6 pb-4 md:px-10 md:pb-6">

    <!-- Badge — banner dışında beyaz alanda -->
    <div class="pb-2 pt-3 md:pb-3 md:pt-4">
      <span class="flex w-full items-center gap-1 rounded-md bg-[#ede8ff] px-2.5 py-1 text-[14px] font-semibold text-[#3b6ef0] md:inline-flex md:w-auto md:gap-1.5 md:bg-gradient-to-r md:from-[#7c5cfc]/12 md:to-[#3b6ef0]/12 md:px-3 md:py-1 md:text-[18px]">
        <Icon name="star" size={12} class="shrink-0 text-[#7c5cfc] md:size-[14px]" />
        <span class="leading-tight">TÜRKİYE'NİN İLK VE TEK <br class="md:hidden" />DİJİTAL AKADEMİK ETÜT KULÜBÜ</span>
      </span>
    </div>

    <!-- Banner -->
    <div class="relative min-h-0 flex-1 overflow-hidden rounded-[8px]">
      <!-- Fotoğraf -->
      <Image
        src={heroGorsel}
        alt="Tabletten canlı etüte katılan öğrenci"
        widths={[768, 1280, 1600]}
        sizes="100vw"
        class="absolute inset-0 h-full w-full object-cover object-center"
        loading="eager"
      />
      <!-- Overlay: mobilde düzgün, masaüstünde soldan sağa gradient -->
      <div class="absolute inset-0 bg-[rgba(28,55,185,0.75)] md:hidden"></div>
      <div class="hero-desktop-overlay absolute inset-0 hidden md:block"></div>

      <!-- İçerik katmanı -->
      <div class="absolute inset-0 z-10 flex flex-col justify-center px-5 py-4 md:justify-evenly md:px-10 md:py-10">

        <!-- Üst: başlık + alt yazı -->
        <div class="max-w-xl">
          <h1 class="font-baslik text-[1.7rem] font-extrabold tracking-tight text-white md:text-[2.8rem] lg:text-[3.5rem]" style="line-height: 1.2;">
            <span class="block whitespace-nowrap md:hidden md:whitespace-normal">Çocuklarınız<br />Bizimle Etütteyken<br />Siz Veli Olmanın<br />Keyfini Sürün</span>
            <span class="hidden md:inline">Çocuklarınız Bizimle Etütteyken Siz Veli Olmanın Keyfini Sürün!</span>
          </h1>
          <p class="mt-6 text-left text-sm text-white/80 md:mt-4 md:text-base">
            <span class="md:hidden">Canlı Etütler, Dijital Dersler,<br />Canlı Soru Çözüm Desteği,<br />Akademik Takip ve Gerçek Koç ile<br />Çocuğunuz Düzenli Çalışsın;<br />Siz Sadece Gelişimini İzleyin.</span>
            <span class="hidden md:inline">Canlı Etütler, Dijital Dersler, Canlı Soru Çözüm Desteği, Akademik Takip ve Gerçek Koç ile Çocuğunuz Düzenli Çalışsın; Siz Sadece Gelişimini İzleyin.</span>
          </p>
        </div>

        <!-- Alt: CTA + not -->
        <div class="mt-6 md:mt-0">
          <a
            href={UYELIK_URL}
            class="inline-flex items-center gap-2 rounded-buton bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] py-1.5 pl-4 pr-1.5 text-sm font-semibold text-beyaz shadow-[0_12px_30px_rgba(40,40,120,.35)] transition hover:brightness-105 md:gap-3 md:py-2.5 md:pl-6 md:pr-2.5 md:text-base"
          >
            Ücretsiz Deneyim
            <span class="grid h-7 w-7 place-items-center rounded-full bg-white text-[#3b6ef0] md:h-9 md:w-9">
              <Icon name="arrow" size={15} />
            </span>
          </a>
          <p class="mt-1 text-xs font-medium text-white/90 md:text-sm">
            2 Haftalık Ücretsiz Deneyim boyunca kredi kartı kaydetmeniz gerekmez.
          </p>
        </div>

      </div>
    </div>
  </div>
</div>

<style is:global>
  .hero-desktop-overlay {
    background: linear-gradient(to right, rgba(30,60,200,0.82) 0%, rgba(30,60,200,0.60) 30%, rgba(30,60,200,0.22) 60%, rgba(30,60,200,0.06) 100%);
  }
</style>
