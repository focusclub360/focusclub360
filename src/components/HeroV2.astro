---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import { KAYIT_URL } from '../config';
import heroGorsel from '../assets/hero-masaustu.jpg';
---

<div class="flex min-h-[calc(100svh-11rem)] flex-col lg:min-h-[calc(100vh-9rem)]">
  <div class="flex min-h-0 flex-1 flex-col px-6 pb-4 pt-3 md:px-10 md:pb-6 lg:pt-0">

    <!-- Badge — yalnızca masaüstü (mobil/tablette sticky header'da) -->
    <div class="hidden pb-3 pt-4 lg:block">
      <span class="inline-flex items-center gap-1.5 rounded-md bg-gradient-to-r from-[#7c5cfc]/12 to-[#3b6ef0]/12 px-3 py-1 text-[18px] font-semibold text-[#3b6ef0]">
        <Icon name="star" size={14} class="shrink-0 text-[#7c5cfc]" />
        TÜRKİYE'NİN İLK VE TEK DİJİTAL AKADEMİK ETÜT KULÜBÜ
      </span>
    </div>

    <!-- Banner -->
    <div class="relative min-h-0 flex-1 overflow-hidden rounded-[8px]">
      <!-- Fotoğraf -->
      <Image
        src={heroGorsel}
        alt="Tabletten canlı etüte katılan öğrenci"
        widths={[768, 1280, 1600]}
        sizes="100vw"
        class="absolute inset-0 h-full w-full object-cover object-center"
        loading="eager"
      />
      <!-- Overlay: mobilde düzgün, masaüstünde soldan sağa gradient -->
      <div class="absolute inset-0 bg-[rgba(28,55,185,0.75)] md:hidden"></div>
      <div class="hero-desktop-overlay absolute inset-0 hidden md:block"></div>

      <!-- İçerik katmanı -->
      <div class="absolute inset-0 z-10 flex flex-col justify-center px-5 py-4 md:px-10 md:py-10">

        <!-- Başlık -->
        <div class="max-w-xl">
          <h1 class="font-baslik text-[1.7rem] font-extrabold leading-[1.44] tracking-tight text-white md:text-[2.8rem] md:leading-[1.2] lg:text-[3.5rem]">
            <span class="block whitespace-nowrap md:hidden md:whitespace-normal">Çocuklarınız<br />Bizimle Etütteyken<br />Siz Veli Olmanın<br />Keyfini Sürün</span>
            <span class="hidden md:inline">Çocuklarınız Bizimle Etütteyken Siz Veli Olmanın Keyfini Sürün!</span>
          </h1>
        </div>

        <!-- CTA + not -->
        <div class="mt-8 md:mt-10">
          <a
            href={KAYIT_URL}
            class="inline-flex items-center gap-2 rounded-buton bg-gradient-to-r from-[#7c5cfc] to-[#3b6ef0] py-1.5 pl-4 pr-1.5 text-sm font-semibold text-beyaz shadow-[0_12px_30px_rgba(40,40,120,.35)] transition hover:brightness-105 md:gap-3 md:py-2.5 md:pl-6 md:pr-2.5 md:text-base"
          >
            Ücretsiz Deneyim
            <span class="grid h-7 w-7 place-items-center rounded-full bg-white text-[#3b6ef0] md:h-9 md:w-9">
              <Icon name="arrow" size={15} />
            </span>
          </a>
          <p class="mt-5 text-xs font-medium text-white/90 md:mt-6 md:text-sm">
            2 Haftalık Ücretsiz Deneyim için kredi kartınızı kaydetmeniz gerekmez.
          </p>
        </div>

      </div>
    </div>
  </div>
</div>

<style is:global>
  .hero-desktop-overlay {
    background: linear-gradient(to right, rgba(30,60,200,0.82) 0%, rgba(30,60,200,0.60) 30%, rgba(30,60,200,0.22) 60%, rgba(30,60,200,0.06) 100%);
  }
</style>
