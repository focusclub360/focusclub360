---
import { Image } from 'astro:assets';
import tubitak from '../assets/tubitak-beyaz logo.png';
import ytuTeknopark from '../assets/yet-teknopark-beyaz-logo.png';
---

<section class="bg-white px-6 pb-10 pt-4 md:px-10 md:pb-12">
  <div class="mx-auto max-w-[1400px]">
    <div class="reveal flex items-center justify-center gap-6">
      <div class="flex h-[140px] w-[180px] items-center justify-center rounded-[8px] border border-kenar bg-[#1b2a5b] p-5 shadow-kucuk">
        <Image src={tubitak} alt="TÜBİTAK" height={100} class="h-full w-full object-contain" />
      </div>
      <div class="flex h-[140px] w-[180px] items-center justify-center rounded-[8px] border border-kenar bg-[#1b2a5b] p-5 shadow-kucuk">
        <Image src={ytuTeknopark} alt="YTÜ Teknopark" height={100} class="h-full w-full object-contain" />
      </div>
    </div>
  </div>
</section>
